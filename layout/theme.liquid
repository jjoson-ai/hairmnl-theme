    {%- comment -%}
      tyio.1 v2 (bd hairmnl-theme-njj1): Defer LoyaltyLion init on /cart until
      first user interaction.

      v1 used document.createElement override (BROKEN — release() fired
      prematurely on synthetic page-load events, restoring _origCE before
      llDefer's flushLL had populated _deferred. Scripts loaded at t≈7.4s
      through the restored original createElement).

      v2 intercepts Element.prototype.appendChild + insertBefore instead.
      These fire immediately before the browser inserts a <script> into the
      DOM — BEFORE loading starts, and independent of release() timing.
      When llDefer's run() calls document.head.appendChild(scriptEl) at t≈8s,
      we catch the node, stash its src, and return the node without inserting
      it. On first click/touchstart/keydown, we restore the originals and
      re-inject the stashed srcs.
    {%- endcomment -%}
    <script>
    (function() {
      var BLOCKED = 'loyaltylion.net';
      var _released = false;
      var _deferred = [];
      var _proto = Element.prototype;
      var _origAC = _proto.appendChild;
      var _origIB = _proto.insertBefore;
      function _guard(node) {
        return !_released &&
               node &&
               node.nodeName === 'SCRIPT' &&
               typeof node.src === 'string' &&
               node.src.indexOf(BLOCKED) !== -1;
      }
      _proto.appendChild = function(node) {
        if (_guard(node)) { _deferred.push(node.src); return node; }
        return _origAC.call(this, node);
      };
      _proto.insertBefore = function(node, ref) {
        if (_guard(node)) { _deferred.push(node.src); return node; }
        return _origIB.call(this, node, ref);
      };
      function release() {
        if (_released) return;
        _released = true;
        _proto.appendChild = _origAC;
        _proto.insertBefore = _origIB;
        _deferred.forEach(function(src) {
          var s = document.createElement('script');
          s.src = src;
          _origAC.call(document.head, s);
        });
        _deferred = [];
      }
      ['click','touchstart','keydown'].forEach(function(ev) {
        document.addEventListener(ev, release, {once: true, passive: true});
      });
    })();
    </script>
    {%- endif -%}

