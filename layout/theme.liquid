        if (e.detail.type == 'open' || e.detail.type == 'embedOpen') {
          gtag('event', 'form_open', 'Klaviyo form', e.detail.formId);
        }
        if (e.detail.type == 'submit') {
          gtag('event', 'form_submit', 'Klaviyo form', e.detail.formId);
