      if (root[root.length - 1] !== '/') {
        root = `${root}/`;
      }
      var theme = {
        routes: {
          root_url: root,
          cart: '{{ routes.cart_url }}',
          cart_add_url: '{{ routes.cart_add_url }}',
          product_recommendations_url: '{{ routes.product_recommendations_url }}'
