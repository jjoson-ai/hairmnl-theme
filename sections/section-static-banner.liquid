<div class="wrapper">
  <div class="static-banner-box">
    {% if section.settings.banner_url != blank %}
      <a href="{{section.settings.banner_url}}">
        <img class="static-banner-img hidden-pocket" src="{{ section.settings.banner_desktop | img_url: 'x788' }}" alt="Static Banner">
        <img class="static-banner-img hidden-lap-and-up" src="{{ section.settings.banner_mobile | img_url: 'x502' }}" alt="Static Banner">
      </a>
    {% else %}
      <img class="static-banner-img hidden-pocket" src="{{ section.settings.banner_desktop | img_url: 'x788' }}" alt="Static Banner">
      <img class="static-banner-img hidden-lap-and-up" src="{{ section.settings.banner_mobile | img_url: 'x502' }}" alt="Static Banner">
    {% endif %}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .static-banner {
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .static-banner {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
</style>

{% schema %}
  {
    "name": "Static Banner",
    "class": "static-banner",
    "settings": [
      {
        "type": "range",
        "id": "section_margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin top",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin bottom",
        "default": 20
      },
      {
        "type": "image_picker",
        "id": "banner_desktop",
        "label": "Banner(Desktop)",
        "info": "1400px width x 788px height recommended"
      },
      {
        "type": "image_picker",
        "id": "banner_mobile",
        "label": "Banner(Mobile)",
        "info": "552px width x 502px height recommended"
      }, {
        "type": "url",
        "id": "banner_url",
        "label": "Banner URL"
      },
      {
        "type": "header",
        "content": "Section Padding(Desktop)"
      }, {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Desktop)",
        "default": 16
      }, {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Desktop)",
        "default": 16
      },
      {
        "type": "header",
        "content": "Section Padding(Mobile)"
      }, {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Mobile)",
        "default": 96
      }, {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Mobile)",
        "default": 96
      }
    ],
    "presets": [
      {
        "name": "Static Banner",
        "category": "Banner"
      }
    ]
  }
{% endschema %}