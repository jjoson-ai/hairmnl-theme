{%- assign banner_alt = section.settings.banner_alt | default: page.title | default: 'Banner' | escape -%}
<div class="wrapper">
  <div class="static-banner-box">
    {%- comment -%}
      <picture> + <source> so mobile only downloads the mobile image
      (was both, hidden via display:none — wasted bandwidth).
    {%- endcomment -%}
    {% if section.settings.banner_url != blank %}
      <a href="{{section.settings.banner_url}}">
        <picture>
          <source media="(min-width: 1009px)" srcset="{{ section.settings.banner_desktop | img_url: 'x788' }}">
          <img class="static-banner-img" src="{{ section.settings.banner_mobile | img_url: 'x502' }}" alt="{{ banner_alt }}">
        </picture>
      </a>
    {% else %}
      <picture>
        <source media="(min-width: 1009px)" srcset="{{ section.settings.banner_desktop | img_url: 'x788' }}">
        <img class="static-banner-img" src="{{ section.settings.banner_mobile | img_url: 'x502' }}" alt="{{ banner_alt }}">
      </picture>
    {% endif %}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .static-banner {
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .static-banner {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
</style>

{% schema %}
  {
    "name": "Static Banner",
    "class": "static-banner",
    "settings": [
      {
        "type": "range",
        "id": "section_margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin top",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin bottom",
        "default": 20
      },
      {
        "type": "image_picker",
        "id": "banner_desktop",
        "label": "Banner(Desktop)",
        "info": "1400px width x 788px height recommended"
      },
      {
        "type": "image_picker",
        "id": "banner_mobile",
        "label": "Banner(Mobile)",
        "info": "552px width x 502px height recommended"
      }, {
        "type": "text",
        "id": "banner_alt",
        "label": "Image alt text (SEO)",
        "info": "Describe what's in the image for screen readers and search engines. Falls back to page title if blank."
      }, {
        "type": "url",
        "id": "banner_url",
        "label": "Banner URL"
      },
      {
        "type": "header",
        "content": "Section Padding(Desktop)"
      }, {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Desktop)",
        "default": 16
      }, {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Desktop)",
        "default": 16
      },
      {
        "type": "header",
        "content": "Section Padding(Mobile)"
      }, {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Mobile)",
        "default": 96
      }, {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Mobile)",
        "default": 96
      }
    ],
    "presets": [
      {
        "name": "Static Banner",
        "category": "Banner"
      }
    ]
  }
{% endschema %}