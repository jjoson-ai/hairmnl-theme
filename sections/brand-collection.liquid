<!-- /sections/brand-collection.liquid — P8 consolidated from 31 P6 brand sections -->
<!-- Source: P6 sections/collection-lp-vitamino.liquid (canonical base), normalized to large-up--* grid -->

{%- assign grid_offset = '' -%}
{%- assign products_count = collection.products_count -%}
{%- case section.settings.grid_setting_large -%}
  {%- when 1 -%}
    {%- assign grid_width_large = 'large-up--one-whole' -%}
  {%- when 2 -%}
    {%- assign grid_width_large = 'large-up--one-half' -%}
    {%- if products_count == 1 -%}
      {%- assign grid_offset = 'push--large-up--one-quarter' -%}
    {%- endif -%}
  {%- when 3 -%}
    {%- assign grid_width_large = 'large-up--one-third' -%}
    {%- if products_count == 1 -%}
      {%- assign grid_offset = 'push--large-up--one-third' -%}
    {%- elsif products_count == 2 -%}
      {%- assign grid_offset = '' -%}
    {%- endif -%}
  {%- when 4 -%}
    {%- assign grid_width_large = 'large-up--one-quarter' -%}
    {%- if products_count == 1 -%}
      {%- assign grid_offset = 'push--large-up--three-eighths' -%}
    {%- elsif products_count == 2 -%}
      {%- assign grid_offset = 'push--large-up--one-quarter' -%}
    {%- elsif products_count == 3 -%}
      {%- assign grid_offset = 'push--large-up--one-eighth' -%}
    {%- endif -%}
  {%- when 5 -%}
    {%- assign grid_width_large = 'large-up--one-fifth' -%}
    {%- if products_count == 1 -%}
      {%- assign grid_offset = 'push--large-up--two-fifths' -%}
    {%- elsif products_count == 2 -%}
      {%- assign grid_offset = 'push--large-up--three-tenths' -%}
    {%- elsif products_count == 3 -%}
      {%- assign grid_offset = 'push--large-up--one-fifth' -%}
    {%- elsif products_count == 4 -%}
      {%- assign grid_offset = 'push--large-up--one-tenth' -%}
    {%- endif -%}
  {%- when 6 -%}
    {%- assign grid_width_large = 'large-up--one-sixth' -%}
    {%- if products_count == 1 -%}
      {%- assign grid_offset = 'push--large-up--five-twelfths' -%}
    {%- elsif products_count == 2 -%}
      {%- assign grid_offset = 'push--large-up--two-sixths' -%}
    {%- elsif products_count == 3 -%}
      {%- assign grid_offset = 'push--large-up--three-twelfths' -%}
    {%- elsif products_count == 4 -%}
      {%- assign grid_offset = 'push--large-up--one-sixth' -%}
    {%- elsif products_count == 5 -%}
      {%- assign grid_offset = 'push--large-up--one-twelfth' -%}
    {%- endif -%}
{%- endcase -%}
{%- case section.settings.grid_setting_medium -%}
  {%- when 1 -%}
    {%- assign grid_width_medium = 'medium--one-whole' -%}
  {%- when 2 -%}
    {%- assign grid_width_medium = 'medium--one-half' -%}
  {%- when 3 -%}
    {%- assign grid_width_medium = 'medium--one-third' -%}
  {%- when 4 -%}
    {%- assign grid_width_medium = 'medium--one-quarter' -%}
{%- endcase -%}
{%- case section.settings.grid_setting_small -%}
  {%- when 1 -%}
    {%- assign grid_width_small = 'small--one-whole' -%}
  {%- when 2 -%}
    {%- assign grid_width_small = 'small--one-half' -%}
  {%- when 3 -%}
    {%- assign grid_width_small = 'small--one-third' -%}
{%- endcase -%}

{%- assign product_count = 48 -%}
{%- if grid_width_large == 'large-up--one-whole' -%}
  {%- assign product_count = 20 -%}
{%- elsif grid_width_large == 'large-up--one-half' -%}
  {%- assign product_count = 50 -%}
{%- elsif grid_width_large == 'large-up--one-third' -%}
  {%- assign product_count = 48 -%}
{%- elsif grid_width_large == 'large-up--one-quarter' -%}
  {%- assign product_count = 48 -%}
{%- elsif grid_width_large == 'large-up--one-fifth' -%}
  {%- assign product_count = 50 -%}
{%- endif -%}
{%- assign display_count = product_count -%}
{%- unless request.design_mode -%}
  {%- assign display_count = section.settings.initial_grid_count | default: 12 -%}
{%- endunless -%}
{%- assign collection_sidebar = false -%}
{%- if section.settings.collection_custom_nav_list != blank or section.settings.collection_standard_nav or section.settings.collection_type_nav or section.settings.collection_vendor_nav or section.settings.collection_tag_nav -%}
  {%- assign collection_sidebar = true -%}
{%- endif -%}

{%- assign brand_title = section.settings.brand_name -%}
{%- if brand_title == blank -%}
  {%- assign brand_title = collection.title -%}
{%- endif -%}

{%- if request.design_mode or request.page_type == null -%}
  {%- comment -%}
    Theme Editor preview OR Section Rendering API request (?section_id=...):
    render the full section normally.
  {%- endcomment -%}
{%- paginate collection.products by display_count -%}
<div data-section-id="{{ section.id }}" data-section-type="collection">
    
  <div class="collection collection-branded">
    {% unless collection.image %}
      <div class="wrapper collection-title text-center color-text {{ section.settings.text_color }}">
        <div class="grid">
          <h1 class="title grid__item one-whole">{{ collection.title }}</h1>
          {% if collection.description.size > 0 %}
            <div class="collection-text--body rte grid__item large-up--three-fifths push--large-up--one-fifth">
              <p>{{ collection.description }}</p>
            </div>
          {% endif %}
        </div>
      </div>
    {% endunless %}
    <div class="wrapper">
      {% if section.settings.collection_sorting or collection_sidebar %}
        {% if collection_sidebar %}
          <div class="text-left">
            <button id="toggleFilters" class="left btn btn--clear uppercase toggle-filters">
              <img src="{{ 'nav.svg' | asset_url }}" width="20" height="20" alt="{{ 'collections.sidebar.more' | t }}"/>
            </button>
          </div>
        {% endif %}
        {% if section.settings.collection_sorting %}
          <div class="row text-right collection__sort">
            {% render 'collection-sorting' %}
          </div>
        {% endif %}
        <hr class="hr--small">
      {% endif %}
      <div class="page-margin grid collection-sidebar">
        {% if collection_sidebar %}
          <div class="grid__item large-up--one-quarter collection-filters" id="collectionFilters">
            {% comment %}
              {% if collection.image %}
                <div class="brand-logo desktop-only">
                  <img src="{{ collection.image | img_url: "500x" }}" alt="{{ collection.title }} Logo">
                </div>
              {% endif %}
            {% endcomment %}
            {% render 'collections-sidebar' %}
          </div>
        {% endif %}
        {% if collection_sidebar %}
          <div class="grid__item large-up--three-quarters">
        {% else  %}
          <div class="grid__item one-whole">
        {% endif %}
          <div class="page-header text-center">
            {% if section.settings.brand_logo %}
              <div class="brand-logo">
                <img src="{{ section.settings.brand_logo | img_url: '500x' }}" width="{{ section.settings.brand_logo.width }}" height="{{ section.settings.brand_logo.height }}" alt="{{ brand_title }} Logo">
              </div>
            {% endif %}

            <h1 class="page_header__title">
              {% if section.settings.brand_page_header_title != blank %}
                {{ section.settings.brand_page_header_title }}
              {% else %}
                {{ collection.title }}
              {% endif %}
            </h1>

            {% if section.settings.brand_page_header_subtitle != blank %}
              <p class="page_header__subtitle">{{ section.settings.brand_page_header_subtitle }}</p>
            {% else %}
              <p>{{ collection.description }}</p>
            {% endif %}


            {% if section.settings.brand_featured_image %}
              {% assign brand_featured_image = section.settings.brand_featured_image %}
              <div class="collection-brand-image preventOverflow" id="FeaturedImage-{{ section.id }}">
                {% if section.settings.brand_featured_image_link != blank %}
                  <a href="{{ section.settings.brand_featured_image_link }}">
                    <img src="{{ brand_featured_image | img_url: '1400x' }}" srcset="{{ brand_featured_image | img_url: '540x' }} 540w, {{ brand_featured_image | img_url: '720x' }} 720w, {{ brand_featured_image | img_url: '1080x' }} 1080w, {{ brand_featured_image | img_url: '1400x' }} 1400w" sizes="100vw" width="{{ brand_featured_image.width }}" height="{{ brand_featured_image.height }}" alt="{{ brand_featured_image.alt | default: collection.title | escape }}" class="responsive-wide-image" {% if section.settings.parallax %} style="opacity: 0;"{% endif %}/>
                  </a>
                {% else %}
                  <img src="{{ brand_featured_image | img_url: '1400x' }}" srcset="{{ brand_featured_image | img_url: '540x' }} 540w, {{ brand_featured_image | img_url: '720x' }} 720w, {{ brand_featured_image | img_url: '1080x' }} 1080w, {{ brand_featured_image | img_url: '1400x' }} 1400w" sizes="100vw" width="{{ brand_featured_image.width }}" height="{{ brand_featured_image.height }}" alt="{{ brand_featured_image.alt | default: collection.title | escape }}" class="responsive-wide-image" {% if section.settings.parallax %} style="opacity: 0;"{% endif %}/>
                {% endif %}
              </div>
            {% endif %}

            {% if section.settings.brand_featured_text %}
              <div class="collection-text--body rte">
                <div class="h4--body rte brand-featured-text">{{ section.settings.brand_featured_text }}</div>
              </div>
            {% endif %}

            {% if section.settings.brand_description_html %}
              <div class="collection-text--body rte brand-description">
                {{ section.settings.brand_description_html }}
              </div>
            {% endif %}
          </div>

          <!-- Featured Collections -->
          {% assign featured_collection_1_handle = section.settings.featured_collection_1 %}
          {% assign featured_collection_2_handle = section.settings.featured_collection_2 %}
          {% assign featured_collection_3_handle = section.settings.featured_collection_3 %}
          {% assign featured_collection_handles = featured_collection_1_handle | append: ", " | append: featured_collection_2_handle | append: ", " | append: featured_collection_3_handle | split: ", " %}

          {% unless featured_collection_handles.size == 0 %}
            <hr>
            <div class="featured-collections">
              <div class="section-header text-center">
                <h2 class="h2--body rte section-header__title">Featured Collections</h2>
                {% unless section.settings.featured_collection_section_description == blank %}
                  <p class="section-header__description">{{ section.settings.featured_collection_section_description }}</p>
                {% endunless %}
              </div>

              <div class="grid {% if settings.image_autoheight_enable %} image_autoheight_enable{% endif %}">
                {% unless collections[featured_collection_1_handle] == blank %}
                  {% assign featured_collection_1 = collections[featured_collection_1_handle] %}
                  <div class="grid__item large-up--one-third product-grid-item featured-collection">
                    <a href="{{ featured_collection_1.url }}">
                      {% if featured_collection_1.image %}
                        <img src="{{ featured_collection_1.image | img_url: '700x700', crop: 'center' }}" width="700" height="700" alt="{{ featured_collection_1.title }} Collection Image">
                      {% else %}
                        {{ 'collection-1' | placeholder_svg_tag }}
                      {% endif %}
                      <h6 class="featured-collection__title">{{ featured_collection_1.title }}</h6>
                      {% if section.settings.featured_collection_1_subtitle %}
                        <p class="featured-collection__subtitle">{{ section.settings.featured_collection_1_subtitle }}</p>
                      {% endif %}
                    </a>
                  </div>
                {% endunless %}

                {% unless collections[featured_collection_2_handle] == blank %}
                  {% assign featured_collection_2 = collections[featured_collection_2_handle] %}
                  <div class="grid__item large-up--one-third product-grid-item featured-collection">
                    <a href="{{ featured_collection_2.url }}">
                      {% if featured_collection_2.image %}
                        <img src="{{ featured_collection_2.image | img_url: '700x700', crop: 'center' }}" width="700" height="700" alt="{{ featured_collection_2.title }} Collection Image">
                      {% else %}
                        {{ 'collection-1' | placeholder_svg_tag }}
                      {% endif %}
                      <p class="featured-collection__title">{{ featured_collection_2.title }}</p>
                      {% unless section.settings.featured_collection_2_subtitle == blank %}
                        <p class="featured-collection__subtitle">{{ section.settings.featured_collection_2_subtitle }}</p>
                      {% endunless %}
                    </a>
                  </div>
                {% endunless %}

                {% unless collections[featured_collection_3_handle] == blank %}
                  {% assign featured_collection_3 = collections[featured_collection_3_handle] %}
                  <div class="grid__item large-up--one-third product-grid-item featured-collection">
                    <a href="{{ featured_collection_3.url }}">
                      {% if featured_collection_3.image %}
                        <img src="{{ featured_collection_3.image | img_url: '700x700', crop: 'center' }}" width="700" height="700" alt="{{ featured_collection_3.title }} Collection Image">
                      {% else %}
                        {{ 'collection-1' | placeholder_svg_tag }}
                      {% endif %}
                      <p class="featured-collection__title">{{ featured_collection_3.title }}</p>
                      {% unless section.settings.featured_collection_3_subtitle == blank %}
                        <p class="featured-collection__subtitle">{{ section.settings.featured_collection_3_subtitle }}</p>
                      {% endunless %}
                    </a>
                  </div>
                {% endunless %}
              </div>

            </div>
          {% endunless %}

          {% for block in section.blocks %}
            {% case block.type %}
              {% when "section_header" %}
              <!-- Section Heading -->
              <hr>
              <div class="section-header text-center">
                <h2 class="h2--body rte section-header__title">{{ block.settings.section-heading }}</h2>  
                  <div class="text-center"><p>{{ block.settings.section-sub-heading }}</p></div>
              </div>
            
              {% when "3x1_box_right_content" %}
              <!-- 3X1 content & media -->
              <div class="grid 3x1_box_right_content">
                  <div class="mobile-only grid__item">
                    <div>{{ block.settings.right_text_html }}</div>
                  </div>
                  <div class="grid__item small--one-half medium--one-half large-up--one-third product-grid-item">
                    <img src="{{ block.settings.left_media_html | img_url: '1800x' }}" width="{{ block.settings.left_media_html.width }}" height="{{ block.settings.left_media_html.height }}" alt="{{ block.settings.left_media_html_alt }}">
                  </div>
                  <div class="grid__item small--one-half medium--one-half large-up--one-third product-grid-item no-pad-left pad-right-30">
                    <img src="{{ block.settings.middle_media_html | img_url: '1800x' }}" width="{{ block.settings.middle_media_html.width }}" height="{{ block.settings.middle_media_html.height }}" alt="{{ block.settings.middle_media_html_alt }}">
                  </div>
                  <div class="grid__item small--one-half medium--one-half large-up--one-third tagged no-pad-left">
                      <div class="desktop-only">{{ block.settings.right_text_html }}</div>
                  </div>
              </div>
            
              {% when "3x3_grid_tile" %}
              <!-- 3X3 Grid -->
              <div class="grid 3x3_grid_tile margin-bottom-20 collection-branded">
                {% if block.settings.product_image_1 != "" %}
                <div class="grid__item small--one-whole medium--one-third large-up--one-third product-grid-item">
                  <img src="{{ block.settings.product_image_1 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_1.width }}" height="{{ block.settings.product_image_1.height }}" alt="{{ block.settings.product_image_1_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_1 }}</div>
                  {% unless block.settings.link_url_1 == blank %}
                  <a href="{{ block.settings.link_url_1 }}"><h5>{{ block.settings.link_label_1 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_2 != "" %}
                <div class="grid__item small--one-whole medium--one-third large-up--one-third product-grid-item">
                  <img src="{{ block.settings.product_image_2 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_2.width }}" height="{{ block.settings.product_image_2.height }}" alt="{{ block.settings.product_image_2_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_2 }}</div>
                  {% unless block.settings.link_url_2 == blank %}
                  <a href="{{ block.settings.link_url_2 }}"><h5>{{ block.settings.link_label_2 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_3 != "" %}
                <div class="grid__item small--one-whole medium--one-third large-up--one-third product-grid-item">
                  <img src="{{ block.settings.product_image_3 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_3.width }}" height="{{ block.settings.product_image_3.height }}" alt="{{ block.settings.product_image_3_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_3 }}</div>
                  {% unless block.settings.link_url_3 == blank %}
                  <a href="{{ block.settings.link_url_3 }}"><h5>{{ block.settings.link_label_3 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
            </div>
            
            {% when "4x3_grid_tile" %}
              <!-- 4X3 Grid -->
              <div class="grid 3x3_grid_tile margin-bottom-20 collection-branded">
                {% if block.settings.product_image_1 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-quarter product-grid-item">
                  <img src="{{ block.settings.product_image_1 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_1.width }}" height="{{ block.settings.product_image_1.height }}" alt="{{ block.settings.product_image_1_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_1 }}</div>
                  {% unless block.settings.link_url_1 == blank %}
                  <a href="{{ block.settings.link_url_1 }}"><h5>{{ block.settings.link_label_1 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_2 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-quarter product-grid-item">
                  <img src="{{ block.settings.product_image_2 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_2.width }}" height="{{ block.settings.product_image_2.height }}" alt="{{ block.settings.product_image_2_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_2 }}</div>
                  {% unless block.settings.link_url_2 == blank %}
                  <a href="{{ block.settings.link_url_2 }}"><h5>{{ block.settings.link_label_2 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_3 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-quarter product-grid-item">
                  <img src="{{ block.settings.product_image_3 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_3.width }}" height="{{ block.settings.product_image_3.height }}" alt="{{ block.settings.product_image_3_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_3 }}</div>
                  {% unless block.settings.link_url_3 == blank %}
                  <a href="{{ block.settings.link_url_3 }}"><h5>{{ block.settings.link_label_3 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_4 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-quarter product-grid-item">
                  <img src="{{ block.settings.product_image_4 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_4.width }}" height="{{ block.settings.product_image_4.height }}" alt="{{ block.settings.product_image_4_alt }}">
                  <div class="3x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_4 }}</div>
                  {% unless block.settings.link_url_4 == blank %}
                  <a href="{{ block.settings.link_url_4 }}"><h5>{{ block.settings.link_label_4 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
            </div>
            
            {% when "2x3_grid_tile" %}
              <!-- 2X3 Grid -->
              <div class="grid 2x3_grid_tile margin-bottom-20 collection-branded">
                {% if block.settings.product_image_1 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-half product-grid-item">
                  <img src="{{ block.settings.product_image_1 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_1.width }}" height="{{ block.settings.product_image_1.height }}" alt="{{ block.settings.product_image_1_alt }}">
                  <div class="2x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_1 }}</div>
                  {% unless block.settings.link_url_1 == blank %}
                  <a href="{{ block.settings.link_url_1 }}"><h5>{{ block.settings.link_label_1 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
                {% if block.settings.product_image_2 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-half product-grid-item">
                  <img src="{{ block.settings.product_image_2 | img_url: '800x', crop: 'center' }}" width="{{ block.settings.product_image_2.width }}" height="{{ block.settings.product_image_2.height }}" alt="{{ block.settings.product_image_2_alt }}">
                  <div class="2x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_2 }}</div>
                  {% unless block.settings.link_url_2 == blank %}
                  <a href="{{ block.settings.link_url_2 }}"><h5>{{ block.settings.link_label_2 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
            </div>
            
            {% when "1x3_grid_tile" %}
              <!-- 1X3 Grid -->
              <div class="grid 2x3_grid_tile margin-bottom-20 collection-branded">
                {% if block.settings.product_image_1 != "" %}
                <div class="grid__item small--one-whole medium--one-half large-up--one-half product-grid-item">
                  <img src="{{ block.settings.product_image_1 | img_url: '300x300', crop: 'center' }}" width="{{ block.settings.product_image_1.width }}" height="{{ block.settings.product_image_1.height }}" alt="{{ block.settings.product_image_1_alt }}" align="center">
                  <div class="2x3_grid_content margin-top-20 margin-bottom-20">{{ block.settings.description_1 }}</div>
                  {% unless block.settings.link_url_1 == blank %}
                  <a href="{{ block.settings.link_url_1 }}"><h5>{{ block.settings.link_label_1 }}</h5></a>
                  {% endunless %}
                </div>
                {% endif %}
              </div>
            
            {% when "left_media_with_text" %}
                <!-- Left Media with Text -->
                <hr>
                <div class="grid custom-section">
                  <div class="grid__item large-up--two-thirds">
                    {% comment %}
                      TODO: Add alt-text and customisation for image location
                    {% endcomment %}
                    <div class="mobile-only">
                      <h4 class="h4--body rte section-title">{{ block.settings.left_media_with_text_section_title }}</h4>
                    </div>
                    {{ block.settings.left_media_with_text_media_html }}
                  </div>
                  <div class="grid__item large-up--one-third">
                    <div class="desktop-only">
                      <h4 class="h4--body rte section-title">{{ block.settings.left_media_with_text_section_title }}</h4>
                    </div>
                    {{ block.settings.left_media_with_text_copy }}
                  </div>
                </div>

                {% when "right_media_with_text" %}
                  <!-- Right Media with Text -->
                  <hr>
                  <div class="grid custom-section">
                    <div class="grid__item large-up--one-third desktop-only">
                      <h4 class="h4--body rte section-title">{{ block.settings.right_media_with_text_section_title }}</h4>

                      {{ block.settings.right_media_with_text_copy }}
                    </div>
                    <div class="grid__item large-up--two-thirds">
                      {% comment %}
                        TODO: Add alt-text and customisation for image location
                      {% endcomment %}
                      <div class="mobile-only">
                        <h4 class="h4--body rte section-title">{{ block.settings.right_media_with_text_section_title }}</h4>
                      </div>
                      {{ block.settings.right_media_with_text_media_html }}
                    </div>
                    <div class="grid__item large-up--one-third mobile-only">
                      {{ block.settings.right_media_with_text_copy }}
                    </div>
                  </div>

                {% when "left_image_with_text" %}
                  <!-- Left Image with Text -->
                  <!--<hr>-->
                  <div class="grid custom-section">
