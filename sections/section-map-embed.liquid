<div class="wrapper">
  <div class="map-embed-box" style="max-width:{{ section.settings.max_width }}px;margin:0 auto;">
    {%- if section.settings.heading != blank -%}
      <h2 class="map-embed-heading" style="text-align:center;margin:0 0 16px;">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}
    <iframe
      src="https://maps.google.com/maps?q={{ section.settings.query | url_encode }}&z={{ section.settings.zoom }}&output=embed"
      width="100%"
      height="{{ section.settings.height }}"
      style="border:0;display:block;border-radius:4px;"
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="{{ section.settings.iframe_title | default: 'Location map' | escape }}">
    </iframe>
    {%- if section.settings.link_url != blank -%}
      <p style="text-align:center;margin:16px 0 0;">
        <a href="{{ section.settings.link_url }}" target="_blank" rel="noopener">
          {{ section.settings.link_label | default: 'Open in Google Maps' | escape }} &rarr;
        </a>
      </p>
    {%- endif -%}
  </div>
</div>

<style>
  #shopify-section-{{ section.id }} {
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }
  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
</style>

{% schema %}
  {
    "name": "Map Embed",
    "class": "map-embed",
    "settings": [
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Find us on the map"
      },
      {
        "type": "text",
        "id": "query",
        "label": "Map query (lat,lng or address)",
        "info": "Example: 14.5725587,121.059829 — shows a pin at that exact spot."
      },
      {
        "type": "range",
        "id": "zoom",
        "min": 10,
        "max": 19,
        "step": 1,
        "label": "Zoom level",
        "default": 16
      },
      {
        "type": "range",
        "id": "height",
        "min": 200,
        "max": 600,
        "step": 20,
        "unit": "px",
        "label": "Map height",
        "default": 320
      },
      {
        "type": "range",
        "id": "max_width",
        "min": 400,
        "max": 1200,
        "step": 20,
        "unit": "px",
        "label": "Max width",
        "default": 720
      },
      {
        "type": "text",
        "id": "iframe_title",
        "label": "Iframe title (accessibility)",
        "info": "Describes the map for screen readers."
      },
      {
        "type": "url",
        "id": "link_url",
        "label": "Open in Google Maps link"
      },
      {
        "type": "text",
        "id": "link_label",
        "label": "Link label",
        "default": "Open in Google Maps"
      },
      {
        "type": "header",
        "content": "Section Padding (Desktop)"
      },
      {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top",
        "default": 40
      },
      {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom",
        "default": 40
      },
      {
        "type": "header",
        "content": "Section Padding (Mobile)"
      },
      {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top",
        "default": 24
      },
      {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom",
        "default": 24
      }
    ],
    "presets": [
      {
        "name": "Map Embed",
        "category": "Content"
      }
    ]
  }
{% endschema %}
