<div class="wrapper">
<div id='judgeme_all_reviews_page' class="page clearfix jdgm-all-reviews-page">
  <div class="jdgm-all-reviews-page__wrapper">
    <h1 class="jdgm-all-reviews-page__title">{{ page.title }}</h1>
    <div class='jdgm-all-reviews-page__description'>{{ page.content }}</div>

    {% render 'judgeme_all_reviews' %}
  </div>
</div>
</div>

<style>
  .jdgm-all-reviews-page {
    margin-top: {{section.settings.section_margin_top}}px;
    margin-bottom: {{section.settings.section_margin_top}}px;
  }
</style>

{% schema %}
  {
    "name": "Judgeme All Review",
    "class": "judgem-all-review",
    "settings": [
      {
        "type": "range",
        "id": "section_margin_top",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin top",
        "unit": "px",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_margin_bottom",
        "min": 0,
        "max": 100,
        "step": 1,
        "label": "Section margin bottom",
        "unit": "px",
        "default": 20
      }
    ],
    "presets": [
      {
        "name": "Judgeme All Review",
        "category": "Review"
      }
    ]
  }
{% endschema %}