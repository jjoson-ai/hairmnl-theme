<div class="homepage-logos {{ section.settings.bg }}{% if section.settings.title != blank %} homepage-logos--tall{% endif %}">
  <div class="wrapper">

    {% if section.settings.title != blank %}
      <h2 class="home__subtitle">{{ section.settings.title | escape }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="logo-bar">
        {% for block in section.blocks %}
          <div class="logo-bar__item" {{ block.shopify_attributes }}>
            {% if block.settings.link != blank %}
              <a href="{{ block.settings.link }}" class="logo-bar__link" target="_blank" rel="noopener">
            {% endif %}
            {% if block.settings.image != blank %}
              {%- comment -%}
                Native <img loading="lazy"> instead of the legacy
                lazysizes data-src + data-widths pattern. Same
                aspect-ratio reservation on the parent .lazy-image
                wrapper (padding-top trick) so there's no CLS.
                Logos are below the fold on every page they appear,
                lazy is the right default.
              {%- endcomment -%}
              {%- assign _logo = block.settings.image -%}
              <div class="lazy-image logo-bar__image" style="padding-top:{{ 1 | divided_by: _logo.aspect_ratio | times: 100 }}%; background-image: url('{{ _logo | image_url: width: 1, height: 1 }}');">
                <img
                  src="{{ _logo | image_url: width: 220 }}"
                  srcset="{% if _logo.width > 110 %}{{ _logo | image_url: width: 110 }} 110w,{% endif %}
                          {% if _logo.width > 220 %}{{ _logo | image_url: width: 220 }} 220w,{% endif %}
                          {% if _logo.width > 320 %}{{ _logo | image_url: width: 320 }} 320w,{% endif %}
                          {% if _logo.width > 480 %}{{ _logo | image_url: width: 480 }} 480w,{% endif %}"
                  sizes="(min-width: 768px) 160px, 110px"
                  width="{{ _logo.width }}"
                  height="{{ _logo.height }}"
                  loading="lazy"
                  alt="{{ _logo.alt | strip_html | escape }}">
              </div>
              <noscript>
                <img src="{{ _logo | image_url: width: 160 }}" alt="{{ _logo.alt | default: block.settings.title | strip_html | escape }}"/>
              </noscript>
            {% else %}
              {{ 'logo' | placeholder_svg_tag: 'placeholder-svg' }}
            {% endif %}
            {% if block.settings.link != blank %}
              </a>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    {% endif %}

    {% if section.blocks.size == 0 %}
      <div class="text-center">{{ 'home_page.onboarding.no_content' | t }}</div>
    {% endif %}

  </div>
</div>

<style>
  #shopify-section-{{ section.id }} .homepage-logos {
    padding-top: {{ section.settings.desktop_padding_top }}px;
    padding-bottom: {{ section.settings.desktop_padding_bottom }}px;
  }

  @media screen and (max-width: 640px) {
    #shopify-section-{{ section.id }} .homepage-logos {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }
  }
</style>

{% schema %}
  {
    "name": "Logo list",
    "max_blocks": 20,
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Heading",
        "default": "Logo list"
      },
      {
        "type": "select",
        "id": "bg",
        "label": "Background color",
        "default": "palette--light bg--neutral",
        "options": [
          { "value": "palette--light bg--neutral", "label": "Default"},
          { "value": "palette--light bg--accent", "label": "Light"},
          { "value": "palette--dark bg--invert", "label": "Dark"},
          { "value": "palette--dark bg--invert--accent", "label": "Dark accent"}
        ]
      },
      {
        "type": "header",
        "content": "Section Padding(Desktop)"
      }, {
        "type": "range",
        "id": "desktop_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Desktop)",
        "default": 16
      }, {
        "type": "range",
        "id": "desktop_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Desktop)",
        "default": 16
      },
      {
        "type": "header",
        "content": "Section Padding(Mobile)"
      }, {
        "type": "range",
        "id": "mobile_padding_top",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding top(Mobile)",
        "default": 96
      }, {
        "type": "range",
        "id": "mobile_padding_bottom",
        "min": 0,
        "max": 200,
        "step": 4,
        "unit": "px",
        "label": "Padding bottom(Mobile)",
        "default": 96
      }
    ],
    "blocks": [
      {
        "type": "logo_image",
        "name": "Logo",
        "settings": [
          {
            "type": "image_picker",
            "id": "image",
            "label": "Image",
            "info": "640 x 640px .png recommended"
          },
          {
            "type": "url",
            "id": "link",
            "label": "Link",
            "info": "Optional"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Logo list",
        "category": "Image",
        "blocks": [
          {
            "type": "logo_image"
          },
          {
            "type": "logo_image"
          },
          {
            "type": "logo_image"
          },
          {
            "type": "logo_image"
          },
          {
            "type": "logo_image"
          }
        ]
      }
    ]
  }
{% endschema %}
