# HairMNL theme — environment variables template.
#
# Copy to .env (already gitignored) and fill in. The repo's Python scripts
# read os.environ directly — they do NOT load .env automatically. Either:
#   1. source .env                          # bash/zsh
#   2. set -a && source .env && set +a      # auto-export for the shell
#   3. export per-invocation: GA4_PROPERTY_ID=248106289 ./scripts/foo.py
#
# Most credentials are JSON files in ~/.config/, NOT env vars. See README's
# Credentials section for the file inventory. The env vars below are the
# few that scripts actually look up via os.environ.

# ── Required for the perf dashboard + RUM scripts ─────────────────────────

# GA4 property to query. HairMNL's GA4 property — bd memories track its
# binding to the seo-agent-489812 service account.
GA4_PROPERTY_ID=248106289

# Path to the GA4 service account key JSON. The dashboard scripts have a
# default of ~/.config/hairmnl-ga4-key.json; override only if you keep
# the key elsewhere. Either GA4_KEY or GOOGLE_APPLICATION_CREDENTIALS
# can point at it (google-auth picks up the latter automatically).
# GA4_KEY=/Users/you/.config/hairmnl-ga4-key.json
# GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/hairmnl-ga4-key.json

# PSI v5 API key. Preferred storage is macOS Keychain (the dashboard
# script reads from `security find-generic-password -a $USER -s psi-api-key`).
# Use this env var as a fallback for CI / Linux:
#   security add-generic-password -a $USER -s psi-api-key -w "AIza..."
# PSI_API_KEY=AIza-your-psi-key

# ── Optional ──────────────────────────────────────────────────────────────

# Slack incoming webhook for dashboard alerts (RUM <75% good, WoW drops
# >10pp, PSI regression >10, sampling-detected, volume drop). When unset,
# evaluate_alerts() silently skips. See docs/handoff-log.md "2em" entry.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00.../B00.../...

# ── GitHub Actions secrets (set in repo settings → secrets, not here) ─────
# Below are the secret names referenced from .github/workflows/. Do NOT
# commit values for these — they're listed for documentation only.
#
#   SHOPIFY_CLI_PARTNERS_TOKEN   used by admin-file-sync workflow
#   SHOPIFY_FLAG_STORE           value: creations-gdc.myshopify.com
#   PSI_API_KEY                  same as above (CI mirror of the Keychain key)
#   GA                           GA4 service-account JSON content (full file,
#                                pasted as a multiline secret) for the
#                                perf-dashboard CI refresh
