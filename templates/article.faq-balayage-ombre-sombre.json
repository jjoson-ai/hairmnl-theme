      "blocks": {
        "q1": {
          "type": "text",
          "settings": {
            "title": "What’s the difference between balayage, ombre, and sombre?",
            "content": "<p>Balayage is a freehand, hand-painted technique for a natural, sun-kissed effect. Ombre is a more defined dark-to-light gradient from root to tip. Sombre is a softer, subtler ombre with a more gradual transition.</p>"
          }
        },
        "q2": {
          "type": "text",
          "settings": {
            "title": "Which technique looks most natural?",
            "content": "<p>Balayage and sombre give the most natural, blended result, while a classic ombre creates a bolder, more noticeable color transition.</p>"
          }
        },
        "q3": {
          "type": "text",
          "settings": {
            "title": "How do I care for balayage or ombre hair?",
            "content": "<p>Use color-safe, sulfate-free shampoos and toning products to fight brassiness, plus regular moisture and bond treatments to keep lightened ends healthy.</p>"
          }
        }
      },
      "block_order": [
