          }
        },
        "001bc0d1-b54f-4c67-8447-e273adc2f22e": {
          "type": "text",
          "settings": {
            "title": "OLAPLEX repairs all types of hair damage.",
            "text": "<p>Thermal factors: High levels of heat from curling irons, blow dryers, flat irons.</p><p>Chemical factors: Colors, perms, relaxers and keratin treatments.<br/>Mechanical factors: Brushing, friction, tugging and pulling on wet hair.</p><p>Environmental factors: UV Damage from the sun, humidity, extreme hot/ cold weather conditions, pollution.</p>",
            "text_align": "text-left"
          }
        }
