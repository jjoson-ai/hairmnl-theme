    "a42abf84-bd09-4df8-b8e9-770f9971e928": {
      "type": "section-columns",
      "blocks": {
        "template--14476669091939__a42abf84-bd09-4df8-b8e9-770f9971e928-1688711417dc69dd9f-1": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/JULY_2025_HAIRMNL_STUDIO_HAIR_7.jpg",
            "title": "Cut & Color",
            "text": "<p>We offer a customized haircut paired with expert color application to create a refreshed and vibrant look that reflects your individuality and style.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "template--14476669091939__a42abf84-bd09-4df8-b8e9-770f9971e928-1688711417dc69dd9f-0": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Highlights_Color.png",
            "title": "Highlights & Color",
            "text": "<p>This service combines the best of both worlds, seamlessly blending expertly crafted highlights with personalized hair color, resulting in a radiant and dynamic look that reflects your individuality and style.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "template--14476669091939__a42abf84-bd09-4df8-b8e9-770f9971e928-1688711417dc69dd9f-2": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/AUGUST_2025_HAIRMNL_STUDIO_HAIR_1.jpg",
            "title": "Ammonia-Free Hair Color",
            "text": "<p>We offer a gentle and nourishing solution for vibrant hair transformations, providing rich, long-lasting color without the harshness of ammonia, resulting in beautiful, healthy-looking locks.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "8a336397-7e2d-48d2-aeb9-e40111bb7ba7": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/AUGUST_2025_HAIRMNL_STUDIO_HAIR_2.jpg",
            "title": "Full Bleach",
            "text": "<p>This is the ultimate solution for achieving bold and transformative hair looks by expertly lifting and lightening your hair to create a blank canvas for vibrant and creative color expressions that turn heads wherever you go.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        }
      },
