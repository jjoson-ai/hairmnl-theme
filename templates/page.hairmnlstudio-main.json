            "title": "Hairstyling",
            "text": "<p>We deliver professional-grade hairstyling to complement your makeup, creating stunning looks that reflect your unique style and leave a lasting impression.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
