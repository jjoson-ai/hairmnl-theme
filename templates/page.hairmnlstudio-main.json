            "image": "shopify://shop_images/JULY_2025_HAIRMNL_STUDIO_HAIR_1.jpg",
            "title": "Smoothing Treatments",
            "text": "<p>We deliver exceptional results by taming frizz, enhancing manageability, and imparting a glossy finish, allowing you to effortlessly flaunt sleek and polished locks.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
