        "template--14476669091939__316c3ddc-39ae-44f9-b7d9-dcba7ad3bd6d-1688711417dc69dd9f-1": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/JULY_2025_HAIRMNL_STUDIO_HAIR_6.jpg",
            "title": "Digital Perm",
            "text": "<p>This offers a modern take on the classic perm, using advanced technology to create natural-looking, bouncy curls or soft waves that add texture, volume, and a touch of effortless elegance to your hair.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "template--14476669091939__316c3ddc-39ae-44f9-b7d9-dcba7ad3bd6d-1688711417dc69dd9f-2": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/OCT_2025_HAIRMNL_STUDIO_MAKEUP_4.jpg",
            "title": "Makeup",
            "text": "<p>Our expert professional makeup artistry elevates your natural beauty, providing personalized looks tailored to enhance your features and leave you feeling confident and ready for any special event or occasion.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
