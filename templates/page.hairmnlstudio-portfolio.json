          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Client_Reviews_-_Kapitolyo.png",
            "title": "Client Reviews",
            "text": "<p>Our clients are at the heart of everything we do. Here’s what they have to say about their experiences with our team and services.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
