    "section_columns_GAjt3P": {
      "type": "section-columns",
      "blocks": {
        "text_block_if6wpV": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/AUGUST_2025_HAIRMNL_STUDIO_HAIR_1.jpg",
            "title": "Argila Amazonia Treatment",
            "text": "<p>Reveal smoother, healthier hair with the Argila Amazonia Treatment, a vegan smoothing ritual that tames frizz, boosts shine, and enhances manageability. Infused with natural clays and botanical extracts, this treatment transforms unruly strands into soft, silky perfection.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_ytY9M6": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Digital_Perm.jpg",
            "title": "Digital Perm",
            "text": "<p>Transform your hair using advanced perm technology that allows you to achieve natural waves or bouncy curls. See long-lasting volume and effortless texture through this service.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_Rnxc7F": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Hair_Color.jpg",
            "title": "Classic Full Color",
            "text": "<p>Achieve timeless elegance with a single, all-over color tailored to enhance your features. Whether you’re refreshing your current shade or trying something new, this classic service delivers rich, even tones for a polished, cohesive look.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_XR9kdD": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Balayage_7f515270-f842-4ba0-9bc0-36d87140c52b.jpg",
            "title": "Color & Balayage",
            "text": "<p>Achieve a stunning color transformation with depth and dimension in any tone. Enhance your brand new hue with a matching balayage and finish it off with an expert cut by our stylists to achieve a new you.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_K7d6zp": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Julie_Highlights_1.jpg",
            "title": "Full Highlights",
            "text": "<p>Brighten your entire look with full highlights, carefully placed from roots to ends for maximum dimension and radiance. This technique creates a sun-kissed effect that adds depth, movement, and a luminous finish to your hair.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_8EJHwN": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Highlights_2_c9bc546a-98ea-4dcb-a937-4959769f668b.jpg",
            "title": "Partial Highlights",
            "text": "<p>Brighten your look with partial highlights that add soft dimension and light-catching accents. Focused around the face or crown, this technique offers a natural glow and subtle lift without the commitment of full highlights, perfect for a refreshed, sun-kissed finish.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_iTCJqa": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/AUGUST_2025_HAIRMNL_STUDIO_HAIR_3.jpg",
            "title": "Ash Blonde Highlights",
            "text": "<p>Add a touch of cool elegance to your hair with ash blonde highlights. Embrace a chic and contemporary look as our skilled stylists craft a seamless blend of tones that perfectly complements your individual style.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_Kr76wX": {
          "type": "text_block",
          "disabled": true,
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Hair_Color_and_Highlights_3.jpg",
            "title": "High Contrast Highlights",
            "text": "<p>Add a touch of cool elegance to your hair with ash blonde highlights that create depth and dimension. Embrace a chic and contemporary look as our skilled stylists craft a seamless blend of tones that perfectly complements your individual style.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_cmwCFQ": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/JULY_2025_HAIRMNL_STUDIO_HAIR_8.jpg",
            "title": "Fashion Color",
            "text": "<p>Make a bold statement with vibrant, head-turning hues. Whether you're going for soft pastels, striking vivids, or edgy unconventional tones, our expert colorists will craft your perfect shade. Elevate your look with customized techniques and a precision finish for a truly standout transformation.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
        "text_block_VpWCAW": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/HairMNL_Studio_Peekaboo_-_Chaddy.jpg",
            "title": "Custom Hair Color",
            "text": "<p>Add a playful pop of personality with a custom peekaboo color, hidden hues that reveal themselves with every movement. Whether bold or subtle, our stylists will create a vibrant, one-of-a-kind look tailored to your style.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        }
