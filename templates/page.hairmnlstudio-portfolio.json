        "bbde1f1b-11f8-4693-bc64-e653b30147c2": {
          "type": "text_block",
          "settings": {
            "enable_image": true,
            "image": "shopify://shop_images/Professional_Friendly_Stylists_-_Kapitolyo.png",
            "title": "High Quality yet Friendly Service",
            "text": "<p>Our team of skilled stylists combines expertise with a personal touch. They listen and offer advice, giving clients the perfect look with a warm experience.</p>",
            "button_label": "",
            "button_link": "",
            "enable_video": false,
            "video_link": "https://www.youtube.com/watch?v=_9VUPq3SxOc"
          }
        },
