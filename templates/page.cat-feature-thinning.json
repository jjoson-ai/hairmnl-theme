        },
        "efae9050-381b-4e9a-a476-6fe99b49bf17": {
          "type": "text",
          "settings": {
            "title": "",
            "text": "<h5><em>It’s more than anti hair fall!</em></h5><p>⭐ ⭐ ⭐ ⭐ ⭐ </p><p>\"This is the one worth buying from the Genesis line. I was experiencing hair fall and my hair seemed lifeless. I decided to give this a try and the first thing I noticed was my hair and scalp started to feel healthy again.\"</p><p>Annette from Mandaluyong</p>",
            "text_align": "text-left"
          }
        },
        "a580a06a-8d0f-4d1d-8be7-8d01d29938e8": {
          "type": "text",
          "settings": {
            "title": "",
            "text": "<h5><em>Lesser Hair Fall</em></h5><p>⭐ ⭐ ⭐ ⭐ ⭐ </p><p>\"I love this Serum! Smells great and i love the cool effect when applied to the scalp. And most of all, it lessen my hair fall! It's really worth the buy!\"</p><p>Jo A. from Valenzuela</p>",
            "text_align": "text-left"
          }
        }
