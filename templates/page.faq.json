    "faq": {
      "type": "section-faq",
      "blocks": {
        "faq-2": {
          "type": "text",
          "disabled": true,
          "settings": {
            "title": "What areas do you cover?",
            "content": "<p>We deliver nationwide</p>"
          }
        },
        "faq-1": {
          "type": "text",
          "settings": {
            "title": "How much is shipping?",
            "content": "<p><strong>METRO MANILA<br/></strong>Standard shipping for paid orders - ₱50*<br/>Cash On Delivery - ₱150</p><p>*For paid orders, we offer FREE standard shipping within Metro Manila for orders ₱1500+ and for orders with <a href=\"https://www.hairmnl.com/collections/kerastase\" target=\"_blank\">Kérastase</a></p><p><strong>PROVINCES</strong><br/>Standard shipping  - ₱150<br/>COD is <em>not</em> available for provinces</p><p>FREE standard shipping for orders ₱3500+ and for orders with orders with <a href=\"https://www.hairmnl.com/collections/kerastase\" target=\"_blank\">Kérastase</a></p>"
          }
        },
        "d9095303-621a-4923-9401-7487ea47b88d": {
          "type": "text",
          "settings": {
            "title": "When can I expect my order?",
            "content": "<p>Cut off for orders is at <strong>5PM</strong> daily. Please expect your parcels to arrive based on the following lead times per area:</p><p><strong>METRO MANILA<br/></strong>• Paid - standard delivery within 3 days<br/>• Cash on Delivery (COD) - within 6 days</p><p><strong>PROVINCES<br/></strong>• Major cities - within 3 to 20 working days *every Saturday for Rizal<br/>• Islands (Batanes, Coron, Puerto Princesa, Marinduque, Masbate, Mindoro, Catanduanes) - within 15 working days</p>"
          }
        },
        "faq-0": {
          "type": "text",
          "settings": {
            "title": "Can I change my delivery details?",
            "content": "<p>For changes in delivery details, you can reach out to us at hello@hairmnl or <a href=\"https://m.me/hairmnl\" target=\"_blank\" title=\"HairMNL Messenger Chat\">m.me/hairmnl.</a></p>"
          }
        },
        "9dcbe5b4-4734-4ec9-ac9a-d12691b92311": {
          "type": "text",
          "settings": {
            "title": "Can I pick up my order instead?",
            "content": "<p>For store pick up, choose 'Pick Up' under Delivery method.</p><p>To ensure stock availability, please send us a message at <a href=\"https://m.me/hairmnl\" target=\"_blank\" title=\"HairMNL Messenger Chat\">m.me/hairmnl.</a></p><p>Before arranging order pick up, kindly confirm order status with us at <a href=\"https://m.me/hairmnl\" target=\"_blank\" title=\"HairMNL Messenger Chat\">m.me/hairmnl</a> or +69177904455.<br/><br/><strong>STORE PICK UP DETAILS</strong><br/>• Pick up hours: 10AM -6PM daily<br/>• Customers book their own courier for store pick up.<br/>• See exact pick-up location on Google Maps - https://goo.gl/maps/5fBkMr6wudy</p><p><strong>RESERVATION<br/></strong>Orders placed under Pick Up delivery method will remain reserved for <em>3 days.</em> Orders will be cancelled after the 3-day grace period. </p>"
          }
        }
      },
