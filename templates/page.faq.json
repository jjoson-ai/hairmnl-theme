        "template--14240176472163__a65e6ea5-5aa3-4708-88d9-3eea70b4ea32-1676030332ea49b710-2": {
          "type": "text",
          "settings": {
            "title": "How do I purchase a HairMNL gift card?",
            "content": "<p>You can purchase HairMNL gift cards online: <a href=\"https://www.hairmnl.com/products/hairmnl-gift-cards\" target=\"_blank\" title=\"HairMNL Gift Cards\">https://www.hairmnl.com/products/hairmnl-gift-cards</a></p><p>E-gift cards are delivered by email and contain instructions to redeem them at checkout.<br/>Our e-gift cards have no additional processing fees.<br/>COD is <em>not</em> allowed for e-gift cards.</p>"
          }
        }
      },
