        "template--14240176472163__a65e6ea5-5aa3-4708-88d9-3eea70b4ea32-1676030332ea49b710-0": {
          "type": "text",
          "settings": {
            "title": "How do I use a voucher code?",
            "content": "<p>To use an voucher code, proceed with Checkout, then place the code in the 'GIFT CARD OR DISCOUNT CODE' field under Order Summary.</p>"
          }
