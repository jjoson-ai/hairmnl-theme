        "template--14240176472163__a65e6ea5-5aa3-4708-88d9-3eea70b4ea32-1676030332ea49b710-1": {
          "type": "text",
          "disabled": true,
          "settings": {
            "title": "How do I use a voucher code?",
            "content": "<p>Share details about your shipping policies, item returns, or customer service.</p>"
