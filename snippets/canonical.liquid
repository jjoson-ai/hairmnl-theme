{%- comment -%}
  Canonical URL emission — server-rendered, single source of truth.

  Strategy:
  1. Default to Shopify's {{ canonical_url }}.
  2. On collection pages, strip query string so ?page, ?filter, ?sort all
     canonicalize to the base collection URL. Handles ALL collections
     systematically — no per-collection enumeration needed.
  3. Apply known product handle overrides (delete/recreate collisions,
     retired SKUs, etc.). Listed at bottom of this file.
  4. Yield to LimeSpot's canonical when it owns the page
     (curated-variation collections) to avoid duplicate canonical tags.

  Maintenance notes:
  - Product overrides listed here should IDEALLY be 301 redirects in
    Shopify Admin → Content → Navigation → URL Redirects. Server-side
    canonical is a strict upgrade over the old JS-rewrite pattern, but
    301s are stronger. Migrate when bandwidth allows.
  - New paginated collections no longer need a rule added — handled automatically.
{%- endcomment -%}

{%- liquid
  assign canonical_final = canonical_url
  assign skip_canonical = false

  # --- LimeSpot owns the canonical on curated A/B variant collections
  if template contains 'collection' and collection.metafields.LimeSpot['CuratedCollectionVariation'] == 'true'
    assign skip_canonical = true
  endif

  # --- Collection pages: strip query string (pagination, filters, sort)
  if template contains 'collection'
    assign canonical_final = canonical_url | split: '?' | first
  endif

  # --- Known collection handle collisions
  if request.path contains '/collections/aveda-be-curly-1'
    assign canonical_final = 'https://www.hairmnl.com/collections/aveda-be-curly'
  endif

  # --- Product handle overrides (TODO: migrate to 301 redirects in Admin)
  # Grouped by brand for readability.
  case request.path

    # L'Oréal Professionnel
    when '/products/loreal-serie-expert-silver-shampoo-1500ml-1', '/products/loreal-serie-expert-silver-shampoo-300ml'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-serie-expert-silver-shampoo'
    when '/products/loreal-professionnel-inoa-ammonia-free-permanent-hair-color-with-20-vol-developer', '/products/loreal-professionnel-inoa-ammonia-free-permanent-hair-color-tube'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-professionnel-inoa-ammonia-free-starter-set-permanent-hair-color-60ml-with-30-vol-developer-1'
    when '/products/loreal-professionnel-serie-expert-scalp-advanced-anti-discomfort-shampoo-500ml'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-professionnel-serie-expert-scalp-advanced-anti-discomfort-shampoo'
    when '/products/loreal-serie-expert-scalp-advanced-anti-oiliness-shampoo-500ml'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-serie-expert-scalp-advanced-anti-oiliness-shampoo'
    when '/products/loreal-serie-expert-absolut-repair-gold-shampoo-300ml'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-serie-expert-absolut-repair-gold-shampoo'
    when '/products/loreal-professionnel-serioxyl-advanced-denser-hair-shampoo-serum-duo'
      assign canonical_final = 'https://www.hairmnl.com/products/loreal-professionnel-serioxyl-advanced-denser-hair-serum'

    # Wella Professionals
    when '/products/wella-professionals-color-fresh-mask-rose-blaze', '/products/wella-professionals-color-fresh-mask-caramel-glaze', '/products/wella-professionals-color-fresh-mask-copper-glow', '/products/wella-professionals-color-fresh-mask-pearl-blonde', '/products/wella-professionals-color-fresh-mask-lilac-frost', '/products/wella-professionals-color-fresh-mask-golden-gloss'
      assign canonical_final = 'https://www.hairmnl.com/products/wella-professionals-color-fresh-mask-chocolate-touch'
    when '/products/wella-professionals-koleston-perfect-permanent-ppd-free-hair-color-set-20-vol-developer-60ml-for-covering-greys', '/products/wella-professionals-koleston-perfect-ppd-free-permanent-hair-color-set-20-vol-developer-1l-with-free-mask-30ml-for-covering-greys', '/products/wella-professionals-koleston-perfect-ppd-free-permanent-hair-color-starter-kit-for-covering-grays'
      assign canonical_final = 'https://www.hairmnl.com/products/wella-professionals-koleston-perfect-ppd-free-permanent-hair-color-tube-all-shades'

    # Davines
    when '/products/davines-purifying-shampoo-for-oily-or-dry-dandruff-100ml'
      assign canonical_final = 'https://www.hairmnl.com/products/davines-naturaltech-purifying-shampoo-for-scalp-with-oily-or-dry-dandruff'
    when '/products/davines-well-being-shampoo-for-all-kinds-of-hair-100ml'
      assign canonical_final = 'https://www.hairmnl.com/products/davines-naturaltech-well-being-shampoo-for-all-kinds-of-hair'
    when '/products/davines-alchemic-creative-conditioner-in-coral', '/products/davines-alchemic-creative-conditioner-in-pink', '/products/davines-alchemic-creative-conditioner-in-teal', '/products/davines-alchemic-creative-conditioner-in-marine-blue'
      assign canonical_final = 'https://www.hairmnl.com/products/davines-alchemic-creative-conditioner-in-lavander'
    when '/products/davines-the-circle-chronicles-the-renaissance-circle-50ml'
      assign canonical_final = 'https://www.hairmnl.com/products/davines-the-circle-chronicles-the-renaissance-circle'
    when '/products/davines-the-circle-chronicles-the-let-it-go-circle-set-of-3'
      assign canonical_final = 'https://www.hairmnl.com/products/davines-the-circle-chronicles-the-let-it-go-circle'

    # Aveda
    # Note: cool-blonde historically preserved a last-wins quirk from the old JS —
    # it was canonicalized to warm-blonde, not the cool-brown group target.
    when '/products/aveda-color-renewal-color-shine-treatment-warm-brown-150ml'
      assign canonical_final = 'https://www.hairmnl.com/products/aveda-color-renewal-color-shine-treatment-cool-brown-150ml'
    when '/products/aveda-color-renewal-color-shine-treatment-cool-blonde-150ml'
      assign canonical_final = 'https://www.hairmnl.com/products/aveda-color-renewal-color-shine-treatment-warm-blonde-150ml'

    # Revlon Professional
    when '/products/revlon-professional-color-sublime-ammonia-free-hair-color-tube-for-covering-grays'
      assign canonical_final = 'https://www.hairmnl.com/products/revlon-professional-color-sublime-ammonia-free-hair-color-set-for-covering-grays'
    when '/products/revlon-professional-nutri-color-creme-ball-270ml'
      assign canonical_final = 'https://www.hairmnl.com/products/revlon-professionnel-nutri-color-creme-100ml'

    # Schwarzkopf
    when '/products/schwarzkopf-bc-bonacure-scalp-genesis-anti-dandruff-shampoo-200ml'
      assign canonical_final = 'https://www.hairmnl.com/products/schwarzkopf-bc-bonacure-scalp-genesis-anti-dandruff-duo'

    # Tuft
    when '/products/tuft-diamond-plus-6609-2-inch-straightening-hair-iron'
      assign canonical_final = 'https://www.hairmnl.com/products/tuft-diamond-plus-6608-1-inch-straightening-hair-iron'

    # CND
    when '/products/cnd-vinylux-long-wear-polish-in-wisteria-haze'
      assign canonical_final = 'https://www.hairmnl.com/products/cnd-vinylux-long-wear-polish-in-whisper'

    # American Crew (handle-collision cleanup — belongs in Admin 301s)
    when '/products/american-crew-fiber-50g-1'
      assign canonical_final = 'https://www.hairmnl.com/products/american-crew-fiber'

    # OPI Infinite Shine — multiple shades consolidated
    when '/products/opi-infinite-shine-in-bare-my-soul', '/products/opi-infinite-shine-in-tiramisu-for-two', '/products/opi-infinite-shine-in-funny-bunny', '/products/opi-infinite-shine-in-its-a-boy'
      assign canonical_final = 'https://www.hairmnl.com/products/opi-infinite-shine-in-malaga-wine'

  endcase
-%}

{%- unless skip_canonical -%}
  {%- if canonical_final != blank -%}
    <link rel="canonical" href="{{ canonical_final }}">
  {%- endif -%}
{%- endunless -%}
