{% comment %} Wholesale_Club_Product_Prices Start {% endcomment %}
{% assign base_product = product %}
{% assign base_variant = product.selected_or_first_available_variant %}
{% if shop.metafields.sawholesale['base_price'] == blank %}
  {% assign base_price = 'compare_at_price' %}
{% else %}
  {% assign base_price = shop.metafields.sawholesale['base_price'] %}
{% endif %}

{% assign saw_discount = 0 %}{% assign saw_has_discount = false %}

{% if customer.tags != blank %}
  {% for mf in base_product.metafields.sawholesale %}
    {% capture product_customer_tag %}
      {{ mf | first | replace: 'discount_', '' }}{% endcapture %}
    {% if customer.tags contains product_customer_tag %}
      {% assign saw_has_discount = true %}
      {% assign discount_key = product_customer_tag | prepend: 'discount_' %}
      {% assign price_key = product_customer_tag | prepend: 'price_' %}
      {% assign saw_discount = base_product.metafields.sawholesale[discount_key] | divided_by: 100.0 %}
    {% endif %}
  {% endfor %}
{% endif %}

{% assign saw_discount = 1 | minus: saw_discount %}

{% if base_price == 'price' or base_variant.compare_at_price == blank or base_variant.compare_at_price == 0 or base_variant.compare_at_price < base_variant.price %}
  {% assign saw_variant_compare_at_price = base_variant.price %}
{% else %}
  {% assign saw_variant_compare_at_price = base_variant.compare_at_price %}
{% endif %}

{% assign cpe = shop.metafields.sawholesale['cpe'] | default: "true" %}
{% if base_variant.metafields.sawholesale[price_key] != blank and cpe == "true" %}
  {% assign saw_variant_price = base_variant.metafields.sawholesale[price_key] %}
{% else %}
  {% assign saw_variant_price = saw_variant_compare_at_price | times: saw_discount %}
{% endif %}

{% if saw_has_discount == false or saw_variant_price >= saw_variant_compare_at_price %}
  {% assign WCProduct_Price = product.price %}
  {% assign WCProduct_ComparePrice = product.compare_at_price %}
  {% assign WCProduct_PriceMin = product.price_min %}
  {% assign WCProduct_ComparePriceMin = product.compare_at_price_min %}
  {% assign WCProduct_PriceMax = product.price_max %}
  {% assign WCProduct_ComparePriceMax = product.compare_at_price_max %}
  {% assign WCProduct_VariantPrice = base_variant.price %}
  {% assign WCProduct_VariantComparePrice = base_variant.compare_at_price %}
{% else %}
  {% assign WCProduct_Price = saw_variant_price %}
  {% assign WCProduct_PriceMin = product.price_min | times: saw_discount %}
  {% assign WCProduct_PriceMax = product.price_max | times: saw_discount %}
  {% assign WCProduct_ComparePrice = saw_variant_compare_at_price %}
  {% if product.compare_at_price_min != 0 %}
    {% assign WCProduct_ComparePriceMin = product.compare_at_price_min %}
  {% else %}
    {% assign WCProduct_ComparePriceMin = product.price_min %}{% endif %}
  {% if product.compare_at_price_max != 0 %}
    {% assign WCProduct_ComparePriceMax = product.compare_at_price_max %}
  {% else %}
    {% assign WCProduct_ComparePriceMax = product.price_max %}{% endif %}
  {% assign WCProduct_VariantPrice = saw_variant_price %}
  {% assign WCProduct_VariantComparePrice = saw_variant_compare_at_price %}
{% endif %}
{% comment %} Wholesale_Club_Product_Prices End {% endcomment %}
{%- assign product_img_url = product.featured_image.src | img_url: '400x400', crop: 'center' -%}
{%- if grid_width_large == 'large--one-whole' -%}
  {%- assign product_img_url = product.featured_image.src | img_url: '1200x' -%}
{%- elsif grid_width_large == 'large--one-half' -%}
  {%- assign product_img_url = product.featured_image.src | img_url: '900x' -%}
{%- endif -%}

{%- assign on_sale = false -%}
{%- if WCProduct_ComparePrice > WCProduct_Price -%}
  {%- assign on_sale = true -%}
{%- endif -%}

{%- assign sold_out = true -%}
{%- if product.available -%}
  {%- assign sold_out = false -%}
{%- endif -%}

{%- assign new_product = false -%}
{%- assign published_date = product.published_at | date: "%s" -%}
{%- assign now_date = 'now' | date: "%s" -%}
{%- assign age_in_days = now_date | minus: published_date | divided_by: 60 | divided_by: 60 | divided_by: 12 -%}
{%- if age_in_days < settings.tag_new_limit -%}
  {%- assign new_product = true -%}
{%- endif -%}

{%- assign sellout_tag = false -%}
{%- if sold_out and settings.tag_sale -%}
  {%- assign sellout_tag = true -%}
{%- endif -%}

{%- assign new_tag = false -%}
{%- if new_product and settings.tag_new -%}
  {%- assign new_tag = true -%}
{%- endif -%}

{%- assign sale_tag = false -%}
{%- if on_sale and settings.tag_sale -%}
  {%- assign sale_tag = true -%}
{%- endif -%}

{%- assign tagged = false -%}
{%- if sellout_tag or new_tag or sale_tag -%}
  {%- assign tagged = true -%}
{%- endif -%}

{%- capture sticker -%}
  {%- if tagged %}
    {%- if sellout_tag -%}
      <div class="sticker sticker--sold">{{ 'products.product.sold_out' | t }}</div>
    {%- elsif sale_tag -%}
      <div class="sticker sticker--sale">{{ 'products.product.sale' | t }}</div>
    {%- elsif new_tag -%}
      <div class="sticker sticker--new">{{ 'products.product.new' | t }}</div>
    {%- endif -%}
  {%- endif -%}
{%- endcapture -%}

<div class="grid__item {{ grid_offset }} {{ grid_width_small }} {{ grid_width_medium }} {{ grid_width_large }}{% if tagged %} tagged{% endif %} product-grid-item">
  <a href="{{ product.url | within: collection }}" class="grid__image">
    {%- comment -%}
      Responsive srcset (180w/360w/540w/720w/1080w) sized for the
      branded grid (≤25vw desktop, ≤33vw tablet, ≤50vw mobile).
      width/height for CLS reservation. loading="lazy" since this
      grid is below the brand banner (not LCP).
    {%- endcomment -%}
    {%- comment -%}
      WebP rollout pilot — 2026-04-27 (third attempt).
      Earlier attempts failed because they piped `product.featured_image.src`
      (URL string) into image_url, which silently dropped the source line.
      This time we pass `product.featured_image` (raw Image object) into
      the `image_url` filter directly. Per Shopify Liquid docs, image_url
      with `format: 'webp'` returns a Shopify-CDN-served WebP variant —
      30–50% smaller than JPEG at equivalent quality.

      <picture> + <source type="image/webp"> means modern browsers (~98%
      of HairMNL traffic per CrUX) pick the WebP. The <img> stays as the
      fallback for the rare browser that doesn't accept image/webp.

      If verification shows the <source> line missing in rendered HTML,
      the image_url filter may genuinely not work in Pipeline 6.1.3 —
      revert by removing the <picture>/<source> wrapper and keeping just
      the <img>.
    {%- endcomment -%}
    {%- assign _img = product.featured_image -%}
    <picture>
      <source type="image/webp"
              srcset="{{ _img | image_url: width: 180, format: 'webp' }} 180w,
                      {{ _img | image_url: width: 360, format: 'webp' }} 360w,
                      {{ _img | image_url: width: 540, format: 'webp' }} 540w,
                      {{ _img | image_url: width: 720, format: 'webp' }} 720w,
                      {{ _img | image_url: width: 1080, format: 'webp' }} 1080w"
              sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw">
      <img
        src="{{ _img.src | img_url: '540x' }}"
        srcset="{{ _img.src | img_url: '180x' }} 180w,
                {{ _img.src | img_url: '360x' }} 360w,
                {{ _img.src | img_url: '540x' }} 540w,
                {{ _img.src | img_url: '720x' }} 720w,
                {{ _img.src | img_url: '1080x' }} 1080w"
        sizes="(min-width: 1024px) 25vw, (min-width: 640px) 33vw, 50vw"
        width="{{ _img.width }}"
        height="{{ _img.height }}"
        loading="lazy"
        style="height:auto;max-width:100%;"
        alt="{{ _img.alt | default: product.title | replace: 'HairMNL ', '' | replace: 'Hair MNL ', '' | replace: 'hairmnl ', '' | replace: 'HAIRMNL ', '' | strip | strip_html | escape }}">
    </picture>
    {{ sticker }}
    {%- comment -%} product-labels disabled 2026-04-27 pending team decision (bd spz). Renders duplicate sale label alongside .product__badge--custom. Snippet kept in /snippets/ for future re-enable. {%- endcomment -%}
    {%- comment -%} {% render 'product-labels', product: product %} {%- endcomment -%}
  </a>

  <div class="figcaption {{ settings.product_grid_style }} {{ settings.collection_text_alignment | default: 'text-center' }}">
    <a href="{{ product.url | within: collection | capitalize }}">
      <p class="h6 name_wrapper">
        {%- comment -%}
          Strip brand prefix from displayed title — on a brand landing
          page (Kérastase / L'Oreal / Davines etc) the brand is already
          in the page H1 + sidebar; repeating it on every card wraps
          long titles into 6+ lines and overflows the 140px figcaption
          height cap, bleeding content into the next section. Alt text
          and SEO title remain fully qualified.
        {%- endcomment -%}
        {{ product.title | replace: "L'Oréal Professionnel ", '' | replace: "L'Oreal Professionnel ", '' | replace: 'L’Oréal Professionnel ', '' | replace: 'Kérastase ', '' | replace: 'Kerastase ', '' | replace: 'Davines ', '' | replace: 'Naturaltech Davines ', '' | replace: 'AVEDA ', '' | replace: 'Aveda ', '' | replace: 'K18 ', '' | replace: 'Schwarzkopf Professional ', '' | replace: 'Bed Head By TIGI ', '' | replace: 'Wella Professionals ', '' | replace: 'Revlon Professional ', '' }}
      </p>
      <p class="price_wrapper">
        <span class="price{% if on_sale %} on-sale{% endif %}">
          {% if product.price_varies %}
            {{ 'products.general.from' | t }}
          {% endif %}
          <span class="money">{{ WCProduct_Price | money }}</span>
        </span>
        {% comment %}
        {% if sold_out %}
        <br /><em>{{ 'products.product.sold_out' | t }}</em>
        {% endif %}
        {% endcomment %}
        {% if on_sale %}
          <span class="compare-at">
            <span class="money">{{ WCProduct_ComparePrice | money }}</span>
          </span>
        {% endif %}
        {% if product.metafields.spr.reviews %}
          <br/>
          <span class="shopify-product-reviews-badge" data-id="{{ product.id }}"></span>
        {% endif %}
      </p>
    </a>
  </div>
</div>