<!-- /snippets/social-meta-tags.liquid -->

{%- assign og_title = page_title -%}
{%- assign og_url = canonical_url -%}
{%- assign og_type = 'website' -%}
{%- assign og_description = page_description | default: shop.description | default: shop.name -%}
{%- assign og_image_tags = '' -%}
{%- assign twitter_image_tag = '' -%}

{%- if template.name == 'product' -%}
  {%- assign og_title = product.title | strip_html -%}
  {%- assign og_type = 'product' -%}
  {%- if product.media.size > 0 -%}
    {%- capture og_image_tags -%}
      {%- for media in product.media limit: 3 -%}
        {% assign image = media.preview_image %}
        <meta property="og:image" content="https:{{ image | img_url: 'master' }}">
        <meta property="og:image:secure_url" content="https:{{ image | img_url: 'master' }}">
        <meta property="og:image:height" content="{{ image.height }}">
        <meta property="og:image:width" content="{{ image.width }}">
      {%- endfor -%}
    {%- endcapture -%}
    {%- capture twitter_image_tag -%}
      <meta name="twitter:image" content="https:{{ product.featured_media.preview_image | img_url: '1200x1200' }}">
    {%- endcapture -%}
  {%- endif -%}

{%- elsif template.name == 'article' -%}
  {%- assign og_title = article.title | strip_html -%}
  {%- assign og_type = 'article' -%}
  {%- assign og_description = article.excerpt_or_content | strip_html -%}
  {%- assign article_og_image = article.image | default: page_image -%}
  {%- if article_og_image -%}
    {%- capture og_image_tags -%}
      <meta property="og:image" content="https:{{ article_og_image | img_url: 'master' }}">
      <meta property="og:image:secure_url" content="https:{{ article_og_image | img_url: 'master' }}">
      <meta property="og:image:height" content="{{ article_og_image.height }}">
      <meta property="og:image:width" content="{{ article_og_image.width }}">
    {%- endcapture -%}
    {%- capture twitter_image_tag -%}
      <meta name="twitter:image" content="https:{{ article_og_image | img_url: '1200x' }}">
    {%- endcapture -%}
  {%- endif -%}

{%- elsif template.name == 'password' -%}
  {%- assign og_title = shop.name -%}
  {%- assign og_url = shop.url -%}
  {%- assign og_description = shop.description | default: shop.name -%}
  {%- if settings.logo -%}
    {%- capture og_image_tags -%}
      <meta property="og:image" content="{{ settings.logo | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="{{ settings.logo | image_url: width: 1200 }}">
    {%- endcapture -%}
    {%- capture twitter_image_tag -%}
      <meta name="twitter:image" content="{{ settings.logo | image_url: width: 1200 }}">
    {%- endcapture -%}
  {%- endif -%}

{%- elsif template.name == 'page' -%}
  {%- if page.handle contains 'studio' -%}
    {%- capture og_image_tags -%}
      <meta property="og:image" content="{{ 'hmnl-studio-share-img.jpg' | asset_url }}">
      <meta property="og:image:secure_url" content="{{ 'hmnl-studio-share-img.jpg' | asset_url }}">
    {%- endcapture -%}
    {%- capture twitter_image_tag -%}
      <meta name="twitter:image" content="{{ 'hmnl-studio-share-img.jpg' | asset_url }}">
    {%- endcapture -%}
  {%- elsif page_image -%}
    {%- capture og_image_tags -%}
      <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
      <meta property="og:image:secure_url" content="{{ page_image | image_url: width: 1200 }}">
    {%- endcapture -%}
    {%- capture twitter_image_tag -%}
      <meta name="twitter:image" content="{{ page_image | image_url: width: 1200 }}">
    {%- endcapture -%}
  {%- endif -%}

{%- elsif page_image -%}
  {%- capture og_image_tags -%}
    <meta property="og:image" content="{{ page_image | image_url: width: 1200 }}">
    <meta property="og:image:secure_url" content="{{ page_image | image_url: width: 1200 }}">
  {%- endcapture -%}
  {%- capture twitter_image_tag -%}
    <meta name="twitter:image" content="{{ page_image | image_url: width: 1200 }}">
  {%- endcapture -%}
{%- endif -%}


<meta property="og:site_name" content="{{ shop.name }}">
<meta property="og:url" content="{{ og_url }}">
<meta property="og:title" content="{{ og_title | escape }}">
<meta property="og:type" content="{{ og_type }}">
<meta property="og:description" content="{{ og_description | escape }}">
{%- if template.name == 'product' -%}
  <meta property="og:price:amount" content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ shop.currency }}">
{%- endif -%}
{{ og_image_tags }}

<meta name="twitter:site" content="{{ settings.social_twitter_link | split: 'twitter.com/' | last | prepend: '@' }}">
{%- if twitter_image_tag != blank -%}
  <meta name="twitter:card" content="summary_large_image">
{%- else -%}
  <meta name="twitter:card" content="summary">
{%- endif -%}
<meta name="twitter:title" content="{{ og_title | escape }}">
<meta name="twitter:description" content="{{ og_description | escape }}">
{{ twitter_image_tag }}
