{%- comment -%}
  Emits supplementary Product JSON-LD with shippingDetails +
  hasMerchantReturnPolicy on every variant Offer, plus aggregateRating
  if Judge.me reviews exist. Rendered outside the smartseo comment
  wrapper so it survives the SmartSEO server-side rewrite (which
  strips schema inside its tagged comment blocks).

  Google merges multiple Product JSON-LD blocks for the same URL by
  @id, so this co-exists with SmartSEO's existing block. Per-variant
  Offers (one per product.variants entry) ensure shipping/return
  appear on EVERY variant in the SERP, matching SmartSEO's
  ProductGroup which emits one Offer per variant.

  Shipping rules: minimum-viable, non-Kerastase assumption.
  - Metro Manila: PHP 50, 1-3 day transit (after 0-1 day handling)
  - Rest of Philippines: PHP 205, 3-14 day transit
  - Free shipping thresholds, COD, Kerastase brand exceptions, and
    store pickup are intentionally NOT modeled here.

  Return policy: 7-day finite window, customer-paid return shipping
  (returnFees: ReturnFeesCustomerResponsibility — Google's enum value;
  schema.org/CustomerResponsibleForReturnFees was a typo that failed
  Google's validator).
{%- endcomment -%}
{%- capture shipping_details_json -%}
[
  {
    "@type": "OfferShippingDetails",
    "shippingRate": {
      "@type": "MonetaryAmount",
      "value": "50",
      "currency": "PHP"
    },
    "shippingDestination": {
      "@type": "DefinedRegion",
      "addressCountry": "PH",
      "addressRegion": "Metro Manila"
    },
    "deliveryTime": {
      "@type": "ShippingDeliveryTime",
      "handlingTime": {
        "@type": "QuantitativeValue",
        "minValue": 0,
        "maxValue": 1,
        "unitCode": "DAY"
      },
      "transitTime": {
        "@type": "QuantitativeValue",
        "minValue": 1,
        "maxValue": 3,
        "unitCode": "DAY"
      }
    }
  },
  {
    "@type": "OfferShippingDetails",
    "shippingRate": {
      "@type": "MonetaryAmount",
      "value": "205",
      "currency": "PHP"
    },
    "shippingDestination": {
      "@type": "DefinedRegion",
      "addressCountry": "PH"
    },
    "deliveryTime": {
      "@type": "ShippingDeliveryTime",
      "handlingTime": {
        "@type": "QuantitativeValue",
        "minValue": 0,
        "maxValue": 1,
        "unitCode": "DAY"
      },
      "transitTime": {
        "@type": "QuantitativeValue",
        "minValue": 3,
        "maxValue": 14,
        "unitCode": "DAY"
      }
    }
  }
]
{%- endcapture -%}
{%- capture return_policy_json -%}
{
  "@type": "MerchantReturnPolicy",
  "applicableCountry": "PH",
  "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
  "merchantReturnDays": 7,
  "returnMethod": "https://schema.org/ReturnByMail",
  "returnFees": "https://schema.org/ReturnFeesCustomerResponsibility",
  "merchantReturnLink": "https://www.hairmnl.com/policies/refund-policy"
}
{%- endcapture -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "@id": {{ canonical_url | append: '#product' | json }},
  "url": {{ canonical_url | json }},
  "name": {{ product.title | json }},
  {%- if product.featured_image -%}
  "image": {{ product.featured_image | img_url: '600x' | prepend: 'https:' | json }},
  {%- endif -%}
  {%- if product.description != blank -%}
  "description": {{ product.description | strip_html | truncate: 250 | json }},
  {%- endif -%}
  {%- if product.selected_or_first_available_variant.sku != blank -%}
  "sku": {{ product.selected_or_first_available_variant.sku | json }},
  "mpn": {{ product.selected_or_first_available_variant.sku | json }},
  {%- endif -%}
  "brand": {
    "@type": "Brand",
    "name": {{ product.vendor | default: shop.name | json }}
  },
  {%- if product.metafields.reviews.rating.value != blank and product.metafields.reviews.rating_count.value != blank -%}
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "{{ product.metafields.reviews.rating.value }}",
    "reviewCount": "{{ product.metafields.reviews.rating_count.value }}",
    "bestRating": "5",
    "worstRating": "1"
  },
  {%- endif -%}
  "offers": [
    {%- for variant in product.variants -%}
    {
      "@type": "Offer",
      {%- if variant.sku != blank -%}
      "sku": {{ variant.sku | json }},
      {%- endif -%}
      "url": {{ shop.url | append: variant.url | json }},
      "priceCurrency": "PHP",
      "price": {{ variant.price | divided_by: 100.00 | json }},
      "availability": "https://schema.org/{% if variant.available %}InStock{% else %}OutOfStock{% endif %}",
      "itemCondition": "https://schema.org/NewCondition",
      "shippingDetails": {{ shipping_details_json | strip }},
      "hasMerchantReturnPolicy": {{ return_policy_json | strip }}
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
