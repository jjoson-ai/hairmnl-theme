<!-- /snippets/product-tabs.liquid -->
{% comment %}
  {% render 'product-tabs', section: section, product: product %}
{% endcomment %}
{%- if product == nil -%}
  {%- assign product_description_content = 'home_page.onboarding.product_description' | t -%}
{%- endif -%}

{%- if block.settings.style == 'tabs' -%}
  {%- assign tab_links_html = '' -%}
  {%- assign tab_contents_html = '' -%}
  {%- assign count = 0 -%}

  {%- if product_description_content != blank -%}
    {%- capture tab_links_html -%}
      <li class="tab-link tab-link-0" data-block-id="{{ section.id | append: '-0' }}" data-focus-element data-tab="0" tabindex="0" data-attributes-placeholder>{{ 'products.general.description' | t }}</li>
    {%- endcapture -%}

    {%- capture tab_contents_html -%}
      <div class="tab-content tab-content-0">
        <div class="tab-content__holder {% if block.settings.read_more %}tab-content__holder--truncate{% endif %}" {% if block.settings.read_more %}data-truncated-holder{% endif %} >
          <div class="tab-content__inner">
            <div class="tab-content__entry" {% if block.settings.read_more %}data-truncated-content="tab-content__entry--truncate"{% endif %}>
              {% if block.settings.read_more %}
                {{ product_description_content }}
              {% else %}
                {{ product.description | replace: '<iframe ', '<iframe loading="lazy" ' }}
              {% endif %}
            </div>
          </div>

          {% if block.settings.read_more %}  
            <div class="tab-content__actions">
              {{ truncate_html }}
            </div>
          {% endif %}
        </div>
      </div>
    {%- endcapture -%}

    {%- assign count = 1 -%}
  {%- endif -%}

  {%- for i in (1..5) -%}
    {%- assign _title = 'title_' | append: forloop.index -%}
    {%- assign _title = block.settings[_title] -%}

    {%- assign _content = 'raw_content_' | append: forloop.index -%}
    {%- assign _content = block.settings[_content] -%}

      {%- if _title != '' and _content != '' -%}
        {%- assign _mf_resolved = false -%}
        {%- if _content contains 'product.metafields' -%}
          {%- assign _ns_part = _content | split: 'product.metafields.' | last -%}
          {%- assign _ns = _ns_part | split: '.' | first -%}
          {%- assign _key_part = _ns_part | split: '.' | last -%}
          {%- assign _key = _key_part | split: '|' | first | split: ' ' | first | split: '}' | first | strip -%}
          {%- if _ns != blank and _key != blank -%}
            {%- assign _mf = product.metafields[_ns][_key] -%}
            {%- if _mf != blank -%}
              {%- capture _resolved_content -%}{{ _mf }}{%- endcapture -%}
              {%- assign _mf_resolved = true -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
        {%- unless _mf_resolved -%}
          {%- assign _looks_escaped_html = false -%}
          {%- if _resolved_content contains '&lt;' and _resolved_content contains '&gt;' -%}
            {%- assign _escaped_html_tags = '&lt;ol&gt;&lt;/ol&gt;&lt;ul&gt;&lt;/ul&gt;&lt;li&gt;&lt;/li&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;strong&gt;&lt;/strong&gt;&lt;em&gt;&lt;/em&gt;&lt;br&gt;' | split: ';' -%}
            {%- for _etag in _escaped_html_tags -%}
              {%- if _resolved_content contains _etag -%}
                {%- assign _looks_escaped_html = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if _looks_escaped_html == false -%}
              {%- if _resolved_content contains '&lt;ol' or _resolved_content contains '&lt;ul' or _resolved_content contains '&lt;li' or _resolved_content contains '&lt;p' or _resolved_content contains '&lt;div' or _resolved_content contains '&lt;strong' or _resolved_content contains '&lt;em' or _resolved_content contains '&lt;br' -%}
                {%- assign _looks_escaped_html = true -%}
              {%- endif -%}
            {%- endif -%}
            {%- if _looks_escaped_html -%}
              {%- if _resolved_content contains '<' -%}
                {%- assign _test_raw = _resolved_content | split: '<' | last -%}
                {%- unless _test_raw | slice: 0, 1 | plus: 0 > 0 and _test_raw | slice: 0, 1 | plus: 0 < 255 -%}
                  {%- assign _resolved_content = _resolved_content | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&quot;', '"' | replace: '&#39;', "'" | replace: '&amp;', '&' -%}
                {%- endunless -%}
              {%- else -%}
                {%- assign _resolved_content = _resolved_content | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&quot;', '"' | replace: '&#39;', "'" | replace: '&amp;', '&' -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        {%- endunless -%}

        {%- capture tab_links_html -%}
          {{ tab_links_html }}

          <li class="tab-link tab-link-{{ count }}" data-focus-element data-tab="{{ count }}" data-block-id="{{ block.id }}" tabindex="0" {{ block.shopify_attributes }}>{{ _title }}</li>
        {%- endcapture -%}

        {%- capture tab_contents_html -%}
          {{ tab_contents_html }}

          <div class="tab-content tab-content-{{ count }}">
            {{ _resolved_content }}
          </div>
        {%- endcapture -%}

      {%- assign count = count | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
  
  {%- if tab_contents_html -%}  
    <div class="product-tabs" data-tabs-holder>
      <div class="tabs__head product-tabs__head">
        <ul class="tabs product-tabs-title" data-scrollbar data-scrollbar-slider>
          {{ tab_links_html }}
        </ul>

        <button type="button" class="tabs__arrow tabs__arrow--prev product-tabs__arrow product-tabs__arrow--prev is-hidden is-not-relative" data-scrollbar-arrow-prev>
          <span class="visually-hidden">{{ 'general.accessibility.see_all' | t }}</span>
        </button>

        <button type="button" class="tabs__arrow tabs__arrow--next product-tabs__arrow product-tabs__arrow--next is-hidden is-not-relative" data-scrollbar-arrow-next>
          <span class="visually-hidden">{{ 'general.accessibility.see_all' | t }}</span>
        </button>
      </div>
      
      {{ tab_contents_html }}
    </div>
  {%- endif -%}
{%- elsif block.settings.style == 'accordions' -%}
  <div class="product-accordion" data-accordion-group>
    {%- assign accordion_blocks_html = '' -%}
    
    {%- for i in (1..5) -%}
      {%- assign _title = 'title_' | append: forloop.index -%}
      {%- assign _title = block.settings[_title] -%}

      {%- assign _content = 'raw_content_' | append: forloop.index -%}
      {%- assign _content = block.settings[_content] -%}

        {% assign block_id = block.id | append: '-' | append: forloop.index %}

        {%- if _title != '' and _content != '' -%}
        {%- assign _mf_resolved = false -%}
        {%- if _content contains 'product.metafields' -%}
          {%- assign _ns_part = _content | split: 'product.metafields.' | last -%}
          {%- assign _ns = _ns_part | split: '.' | first -%}
          {%- assign _key_part = _ns_part | split: '.' | last -%}
          {%- assign _key = _key_part | split: '|' | first | split: ' ' | first | split: '}' | first | strip -%}
          {%- if _ns != blank and _key != blank -%}
            {%- assign _mf = product.metafields[_ns][_key] -%}
            {%- if _mf != blank -%}
              {%- capture _resolved_content -%}{{ _mf }}{%- endcapture -%}
              {%- assign _mf_resolved = true -%}
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}
        {%- unless _mf_resolved -%}
          {%- assign _looks_escaped_html = false -%}
          {%- if _resolved_content contains '&lt;' and _resolved_content contains '&gt;' -%}
            {%- assign _escaped_html_tags = '&lt;ol&gt;&lt;/ol&gt;&lt;ul&gt;&lt;/ul&gt;&lt;li&gt;&lt;/li&gt;&lt;p&gt;&lt;/p&gt;&lt;div&gt;&lt;/div&gt;&lt;strong&gt;&lt;/strong&gt;&lt;em&gt;&lt;/em&gt;&lt;br&gt;' | split: ';' -%}
            {%- for _etag in _escaped_html_tags -%}
              {%- if _resolved_content contains _etag -%}
                {%- assign _looks_escaped_html = true -%}
                {%- break -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if _looks_escaped_html == false -%}
              {%- if _resolved_content contains '&lt;ol' or _resolved_content contains '&lt;ul' or _resolved_content contains '&lt;li' or _resolved_content contains '&lt;p' or _resolved_content contains '&lt;div' or _resolved_content contains '&lt;strong' or _resolved_content contains '&lt;em' or _resolved_content contains '&lt;br' -%}
                {%- assign _looks_escaped_html = true -%}
              {%- endif -%}
            {%- endif -%}
            {%- if _looks_escaped_html -%}
              {%- if _resolved_content contains '<' -%}
                {%- assign _test_raw = _resolved_content | split: '<' | last -%}
                {%- unless _test_raw | slice: 0, 1 | plus: 0 > 0 and _test_raw | slice: 0, 1 | plus: 0 < 255 -%}
                  {%- assign _resolved_content = _resolved_content | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&quot;', '"' | replace: '&#39;', "'" | replace: '&amp;', '&' -%}
                {%- endunless -%}
              {%- else -%}
                {%- assign _resolved_content = _resolved_content | replace: '&lt;', '<' | replace: '&gt;', '>' | replace: '&quot;', '"' | replace: '&#39;', "'" | replace: '&amp;', '&' -%}
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        {%- endunless -%}

        {%- capture accordion_blocks_html -%}
          {{ accordion_blocks_html }}
          <div class="accordion__wrapper">
            <button class="accordion__title"
              data-accordion-trigger="{{ block_id }}"
              aria-controls="{{ block_id }}"
              aria-haspopup="true" 
              aria-expanded="false">
              {{ _title }}
            </button>

            <div class="accordion__body" id="{{ block_id }}" data-accordion-body>
              {{ _resolved_content }}
            </div>
          </div>
        {%- endcapture -%}
      {%- endif -%}
    {%- endfor -%}
    

    {%- if product_description_content != blank -%}
      {% assign block_id = block.id | append: '-main' %}
      <div class="accordion__wrapper">
        <button class="accordion__title accordion-is-open"
          data-accordion-trigger="{{ block_id }}"
          aria-controls="{{ block_id }}"
          aria-haspopup="true" 
          aria-expanded="false">
          {{ 'products.general.description' | t }}
        </button>

        <div class="accordion__body" id="{{ block_id }}" data-accordion-body>
          <div class="accordion-content__holder {% if block.settings.read_more %}accordion-content__holder--truncate{% endif %}" {% if block.settings.read_more %}data-truncated-holder{% endif %}>
            <div class="accordion-content__inner">
              <div class="accordion-content__entry" {% if block.settings.read_more %}data-truncated-content="accordion-content__entry--truncate"{% endif %}>
                {% if block.settings.read_more %}
                  {{ product_description_content }}
                {% else %}
                  {{ product.description | replace: '<iframe ', '<iframe loading="lazy" ' }}
                {% endif %}
              </div>
            </div>

            {% if block.settings.read_more %}  
              <div class="accordion-content__actions">
                {{ truncate_html }}
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {%- endif -%}

    {{ accordion_blocks_html }}
  </div>
{%- endif -%}
