{%- if upsell_product_list.count > 0 -%}
  <div class="upsell__holder">
    <h2 class="upsell__holder__title">{{ 'products.general.upsell_title' | t }}</h2>
    <script>
      window.upsellProductList = {{upsell_product_list | json}};
    </script>
    {% for upsell_product in upsell_product_list %}
      {% assign current_variant = upsell_product.selected_or_first_available_variant %}
      {%- assign product_form_id = 'product-form-' | append: upsell_product.id -%}
      {%- assign upsell_error = false -%}
      
      {%- if upsell_product.title == '' or current_variant == nil -%}
        {%- assign upsell_error = true -%}
      {%- endif -%}

      {%- if request.design_mode -%}
        {%- assign upsell_error = false -%}
      {%- endif -%}

      {%- unless upsell_error -%}
        {%- if request.design_mode and upsell_product.title == '' or upsell_selected_variant == nil -%}
          {%- assign upsell_error = true -%}
        {%- endif -%}
          <div class="upsell" data-product-id="{{upsell_product.id}}" data-upsell-holder data-add-action-wrapper>
            <div class="upsell__image">
              {%- assign upsell_image = upsell_product.featured_media.preview_image -%}
              {%- if upsell_error -%}
                <div class="upsell__image__inner" style="background-color: var(--bg-accent);"></div>
              {%- elsif upsell_image -%}
                <a href="{{ upsell_product.url }}">
                  <img class="upsell__image__inner" 
                    loading="lazy" 
                    alt="{{ upsell_image.alt | default: upsell_product.title | replace: 'HairMNL ', '' | replace: 'Hair MNL ', '' | replace: 'hairmnl ', '' | replace: 'HAIRMNL ', '' | strip | strip_html | escape }}"
                    src="{{ upsell_image.src | img_url: '180x180', crop: 'center' }}"
                    width="90"
                    height="90">
                </a>
              {%- else -%}
                <a href="{{ upsell_product.url }}">
                  <div class="upsell__image__inner" style="background-color: var(--bg-accent);"></div>
                </a>
              {%- endif -%}
            </div>
        
            <div class="upsell__content">
              {%- if upsell_error -%}
                <h3 class="upsell__title">{{ 'products.general.upsell_error_title' | t }}</h3>
                <p class="small">{{ 'products.general.upsell_error_info' | t }}</p> 
              {%- else -%}  
                  <h3 class="upsell__title">{{ upsell_product.title | strip_html }}</h3>

                  <p class="upsell__variant-title">{{ upsell_product.title | replace: '/', '<span>&nbsp;</span>' }}</p>
        
                  <p class="upsell__price {% if upsell_product.compare_at_price > upsell_product.price %} sale{% endif %}">
                    <span class="new-price">{{ upsell_product.price | money }}</span>  
                    
                    {%- if upsell_product.compare_at_price > upsell_product.price -%}
                      <span class="old-price">{{ upsell_product.compare_at_price | money }}</span>
                    {%- endif -%}
                    
                    {%- if upsell_product.unit_price -%}
                      {%- capture unit_price_separator -%}
                        <span aria-hidden="true">/</span>
                        <span class="visually-hidden">{{ 'general.accessibility.unit_price_separator' | t }}&nbsp;</span>
                      {%- endcapture -%}
        
                      {%- capture unit_price_base_unit -%}
                        {%- if upsell_product.unit_price_measurement.reference_value != 1 -%}
                          {{ upsell_product.unit_price_measurement.reference_value }}
                        {%- endif -%}
                        {{ upsell_product.unit_price_measurement.reference_unit }}
                      {%- endcapture -%}
                      
                    <br />
      
                    <span class="visually-hidden visually-hidden--inline">{{ 'products.product.unit_price_label' | t }}</span>
      
                    <span class="unit">{{ upsell_product.unit_price | money }}{{ unit_price_separator }}{{ unit_price_base_unit }}</span>
                  {% endif -%}
                </p>
                
                {% unless upsell_product.has_only_default_variant %}
                  <div class="form__selectors">
                    {% for option in upsell_product.options_with_values %}
                      {% assign current_value = current_variant.options[forloop.index0] %}
                      <div class="selector-wrapper js" data-split-select-wrapper data-select-label="{{ option.name }}"  data-option-position="{{ option.position }}">
                        <fieldset class="radio__fieldset">
                          <legend class="radio__legend">
                            <span class="radio__legend__label">{{ option.name | escape_once }}</span>
                            <span data-option-current-value>{{ current_value }}</span>
                            {%- if size_chart_index == forloop.index0 -%}
                              {{ size_chart }}
                            {%- endif -%}
                          </legend>

                          {% for value in option.values %}
                            {% unless value contains "% off" %}
                              {% capture input_id %}{{ upsell_product.id }}-{{ block.id }}-{{ option.name | escape_once }}-{{ value | escape_once }}{% endcapture %}

                              {% comment %} radio button {% endcomment %}
                                <span class="radio__button" data-product-id="{{upsell_product.id}}">
                                  <input
                                    type="radio"
                                    name="options[{{ option.name | escape_once }}]"
                                    value="{{ value | escape_once }}" id="{{ input_id }}"
                                    {%- if value == current_value -%}checked{%- endif -%}>
                                  <label for="{{ input_id }}">
                                    <span>{{ value | escape_once }}</span>
                                  </label>
                                </span>
                            {% endunless %}
                          {% endfor %}
                        </fieldset>
                      </div>
                    {% endfor %}
                  </div>
                {% endunless %}
              
                {%- capture form_markup -%}
                  <button
                    data-add-to-cart
                    {% if show_form %} 
                      type="submit" name="add"
                    {% else %}
                      data-add-to-cart-variant="{{upsell_product.selected_or_first_available_variant.id}}"
                    {% endif %}
                    class="upsell__btn uppercase btn--soft btn--small btn--primary 
                    {% unless upsell_product.available %} is-hidden {% endunless %}"> 
                    <span class="btn-state-ready">{{ 'products.general.upsell_add_to_cart' | t }}</span>

                    <span class="btn-state-loading">
                      <svg height="18" width="18" class="svg-loader">
                        <circle r="7" cx="9" cy="9" />
                        <circle stroke-dasharray="87.96459430051421 87.96459430051421" r="7" cx="9" cy="9" />
                      </svg>
                    </span>

                    <span class="btn-state-complete">&nbsp;</span>
                  </button>

                  <p class="upsell__out-of-stock {% if upsell_product.available %} is-hidden{% endif %}">{{ 'products.general.upsell_out_of_stock' | t }}</p>
                {%- endcapture -%}
                
                {%- if show_form -%}  
                  {%- form 'product', upsell_product -%}
                    <input type="hidden" name="id" value="{{ upsell_product.selected_or_first_available_variant.id }}">
                    {{ form_markup }}
                  {%- endform -%}
                {%- else -%}
                  {{ form_markup }}    
                {%- endif -%}
              {%- endif -%}
            </div>
          </div>

          <div data-add-action-errors class="add-action-errors">&nbsp;</div>
      {%- endunless -%}
    {% endfor %}
  </div>
{%- endif -%}