    "url" : "{{- shop.url -}}",
    {%- if settings.pluginseo_structuredDataDisplayLogo == true  -%}
      "logo": "https:{{- logoUrl -}}",
    {%- endif -%}
    "sameAs" : [
      {%- for sociallink in links -%}
        "{{- sociallink -}}"{%- if forloop.last == false -%},{%- endif -%}
