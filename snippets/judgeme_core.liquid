{% comment %}
  Deferred Judge.me core loader.

  Preview-badge stars render statically (see snippets/judgeme_static_stars.liquid),
  so loader.js + Judge.me CSS are only required when a heavier widget is on the page
  (review widget, all-reviews page, featured carousel, floating tab, UGC grid).
  We gate the load behind IntersectionObserver and first-interaction to keep
  loader work off the main thread until it can pay for itself.

  jdgmSettings is still emitted synchronously below so the deferred loader can read it.
{% endcomment %}
<!-- Start of Judge.me Core -->
<link rel="dns-prefetch" href="https://cdn.judge.me/">
{{ shop.metafields.judgeme.settings }}
{% for count in (0..5) %}
  {% assign metafield_key = 'html_miracle_' | append: count %}
  {% assign current_metafield = shop.metafields.judgeme[metafield_key] %}
  {% unless current_metafield %} {% break %} {% endunless %}
  {{ current_metafield }}
{% endfor %}


<script data-cfasync='false' class='jdgm-script'>
(function(d, w){
  if (w.__jdgmDeferredInit) return;
  w.__jdgmDeferredInit = true;
  w.jdgm = w.jdgm || {};
  w.jdgm.CDN_HOST = "https://cdn.judge.me/";

  function loadCSS(href){
    if (loadCSS.requested.indexOf(href) >= 0) return;
    loadCSS.requested.push(href);
    var l = d.createElement("link");
    l.rel = "stylesheet";
    l.className = "jdgm-stylesheet";
    l.media = "nope!";
    l.href = href;
    l.onload = function(){ this.media = "all"; };
    d.body.appendChild(l);
  }
  loadCSS.requested = [];

  function loadJS(src){
    var x = new XMLHttpRequest();
    x.onreadystatechange = function(){
      if (x.readyState === 4) { try { Function(x.response)(); } catch (e) {} }
    };
    x.open("GET", src);
    x.send();
  }

  function fire(){
    if (w.__jdgmFired) return;
    w.__jdgmFired = true;
    var s = w.jdgmSettings || {};
    if (s.widget_load_with_code_splitting) {
      loadCSS(w.jdgm.CDN_HOST + (parseFloat(s.widget_version) >= 3 ? "widget_v3/base.css" : "widget/base.css"));
    } else {
      loadCSS(w.jdgm.CDN_HOST + "shopify_v2.css");
    }
    loadJS(w.jdgm.CDN_HOST + "loader.js");
  }

  function ready(fn){
    if (d.readyState !== "loading") setTimeout(fn, 0);
    else d.addEventListener("DOMContentLoaded", fn);
  }

  ready(function(){
    var heavy = d.querySelectorAll(
      ".jdgm-widget:not(.jdgm-prev-badge), .jdgm-all-reviews-page, .jdgm-revs-tab, .jdgm-carousel-wrapper, .jdgm-ugc-media-wrapper, #judgeme_product_reviews"
    );

    if (heavy.length && "IntersectionObserver" in w) {
      var io = new IntersectionObserver(function(entries){
        for (var i = 0; i < entries.length; i++) {
          if (entries[i].isIntersecting) { io.disconnect(); fire(); return; }
        }
      }, { rootMargin: "300px" });
      for (var i = 0; i < heavy.length; i++) io.observe(heavy[i]);
    } else if (heavy.length) {
      (w.requestIdleCallback || function(f){ setTimeout(f, 1500); })(fire);
    }

    var events = ["pointerdown", "keydown", "touchstart"];
    function onIntent(e){
      var t = e.target;
      if (t && t.closest && t.closest(".jdgm-widget, .jdgm-all-reviews-page, [data-jdgm-trigger]")) {
        fire();
        events.forEach(function(ev){ d.removeEventListener(ev, onIntent, true); });
      }
    }
    events.forEach(function(ev){ d.addEventListener(ev, onIntent, { passive: true, capture: true }); });
  });
})(document, window);
</script>

<noscript><link rel="stylesheet" type="text/css" media="all" href="https://cdn.judge.me/shopify_v2.css"></noscript>
<!-- End of Judge.me Core -->
