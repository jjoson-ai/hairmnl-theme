{%- comment -%}
  Sticky purchase bar — desktop only.

  Two modes:
  - PDP mode (default): appears when primary ATC leaves viewport
    (IntersectionObserver). Per task-2-pdp-progression.md PR-2.
  - Collection mode (is_collection=true): always-visible on collection
    + brand pages (full STKY app replacement). Per bd a7av.8. JS
    hydrates the bar with the last-viewed product from sessionStorage
    if present; otherwise keeps the server-rendered first-product
    fallback. Card clicks on the collection page update the bar
    in-place via the JS in assets/hairmnl-common.js.

  Arguments:
    product       {Product}  required — what to render on first paint
    is_collection {Boolean}  optional, default false — switch to
                  collection always-visible mode

  Mobile/tablet: bar is display:none below 1024px (CSS gate in
  snippets/css-overrides.liquid).
{%- endcomment -%}

{%- liquid
  assign first_variant = product.first_available_variant
  if first_variant == nil
    assign first_variant = product.variants.first
  endif
  assign thumb_img = product.featured_media.preview_image
  assign is_collection_mode = is_collection | default: false
-%}

{%- if product != blank -%}
  <div class="vrec-product-sticky-bar{% if is_collection_mode %} vrec-product-sticky-bar--always-visible is-visible{% endif %}"
       id="vrec-product-sticky-bar"
       data-product-id="{{ product.id }}"
       data-product-handle="{{ product.handle }}"
       data-product-url="{{ product.url }}"
       data-vrec-sticky-mode="{% if is_collection_mode %}collection{% else %}pdp{% endif %}"
       aria-hidden="{% if is_collection_mode %}false{% else %}true{% endif %}">
    {%- if thumb_img -%}
      <div class="vrec-product-sticky-bar__thumb">
        <img src="{{ thumb_img | image_url: width: 96 }}"
             alt=""
             width="48"
             height="48"
             loading="lazy">
      </div>
    {%- endif -%}
    <div class="vrec-product-sticky-bar__info">
      <p class="vrec-product-sticky-bar__title">{{ product.title | strip_html }}</p>
      {%- if product.variants.size > 1 and first_variant -%}
        <p class="vrec-product-sticky-bar__meta" data-vrec-sticky-variant>{{ first_variant.title }}</p>
      {%- elsif product.vendor != blank -%}
        <p class="vrec-product-sticky-bar__meta">{{ product.vendor }}</p>
      {%- endif -%}
    </div>
    <p class="vrec-product-sticky-bar__price" data-vrec-sticky-price>{{ first_variant.price | money }}</p>
    {%- form 'product', product, class: 'vrec-product-sticky-bar__form' -%}
      <input type="hidden" name="id" value="{{ first_variant.id }}" data-vrec-sticky-id>
      <input type="hidden" name="quantity" value="1">
      <button type="submit"
              name="add"
              class="vrec-product-sticky-bar__cta"
              {% unless first_variant.available %}disabled aria-disabled="true"{% endunless %}>
        {%- if first_variant.available -%}
          {{ 'products.product.add_to_cart' | t | default: 'Add to cart' }}
        {%- else -%}
          {{ 'products.product.sold_out' | t | default: 'Sold out' }}
        {%- endif -%}
      </button>
    {%- endform -%}
  </div>

  <script>
    (function () {
      // Desktop-only behavior — skip if viewport <1024 (mobile has its own bar)
      if (window.matchMedia('(max-width: 1023px)').matches) return;

      var bar = document.getElementById('vrec-product-sticky-bar');
      if (!bar) return;

      // Collection mode skips the IntersectionObserver — bar is always visible.
      // Hydration + card-click updates handled in assets/hairmnl-common.js.
      var mode = bar.getAttribute('data-vrec-sticky-mode');
      if (mode === 'collection') {
        // Track PDP-visit on PDP entry doesn't apply here (no product page-view
        // on collection pages). hairmnl-common.js does the hydration work.
        return;
      }

      // PDP mode: find the primary product-form ATC button and observe it.
      // Pipeline uses <form action="/cart/add"> with button[name="add"].
      var primaryATC = document.querySelector(
        'form[action*="/cart/add"]:not(.vrec-product-sticky-bar__form) button[name="add"], ' +
        'form[action*="/cart/add"]:not(.vrec-product-sticky-bar__form) input[name="add"]'
      );
      if (!primaryATC) return;

      // Show the sticky bar when ATC leaves viewport
      var io = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            bar.classList.remove('is-visible');
            bar.setAttribute('aria-hidden', 'true');
          } else {
            bar.classList.add('is-visible');
            bar.setAttribute('aria-hidden', 'false');
          }
        });
      }, { rootMargin: '0px 0px 0px 0px', threshold: 0 });
      io.observe(primaryATC);

      // PDP mode also writes to sessionStorage so the collection-mode bar can
      // hydrate to "last viewed product" on subsequent collection navigation.
      try {
        var sessionPayload = {
          id: bar.getAttribute('data-product-id'),
          handle: bar.getAttribute('data-product-handle'),
          url: bar.getAttribute('data-product-url'),
          title: bar.querySelector('.vrec-product-sticky-bar__title')?.textContent || '',
          price_html: bar.querySelector('.vrec-product-sticky-bar__price')?.innerHTML || '',
          thumb_src: bar.querySelector('.vrec-product-sticky-bar__thumb img')?.src || '',
          variant_id: bar.querySelector('[data-vrec-sticky-id]')?.value || '',
          variant_label: bar.querySelector('[data-vrec-sticky-variant]')?.textContent || '',
          available: !bar.querySelector('.vrec-product-sticky-bar__cta')?.disabled,
          ts: Date.now()
        };
        sessionStorage.setItem('hairmnl_last_viewed_product', JSON.stringify(sessionPayload));
      } catch (e) { /* sessionStorage disabled — silent no-op */ }

      // Keep variant + price in sync. Pipeline fires `variant:change`
      // on the product section when the variant selector updates.
      // Best-effort — if the event shape differs, the sticky bar
      // just keeps the first-variant defaults rendered server-side.
      document.addEventListener('variant:change', function (e) {
        var variant = e && e.detail && (e.detail.variant || e.detail);
        if (!variant) return;
        var idInput = bar.querySelector('[data-vrec-sticky-id]');
        var priceEl = bar.querySelector('[data-vrec-sticky-price]');
        var variantEl = bar.querySelector('[data-vrec-sticky-variant]');
        if (idInput && variant.id) idInput.value = variant.id;
        if (priceEl && variant.price != null) {
          // Variant price is in cents on Shopify Liquid; format defensively.
          var p = variant.price;
          var formatted = typeof p === 'string' ? p : (p / 100).toLocaleString('en-PH', { style: 'currency', currency: 'PHP' });
          priceEl.textContent = formatted;
        }
        if (variantEl && variant.title) variantEl.textContent = variant.title;
        var btn = bar.querySelector('.vrec-product-sticky-bar__cta');
        if (btn && typeof variant.available !== 'undefined') {
          btn.disabled = !variant.available;
        }
      });
    })();
  </script>
{%- endif -%}
