  var events = ['scroll', 'click', 'touchstart', 'mousemove', 'keydown'];
  var opts = { once: true, passive: true, capture: true };
  events.forEach(function (ev) {
    window.addEventListener(ev, flushLL, opts);
  });
  setTimeout(flushLL, 8000);

  !function (t, n, llDefer) {
    function o(url) {
      var run = function () {
        var anchor = t.getElementsByTagName('script')[0],
          el = t.createElement('script');
        el.src = url;
        el.crossOrigin = '';
        anchor.parentNode.insertBefore(el, anchor);
      };
      if (!llDefer.released) {
        llDefer.queue.push(run);
        return;
      }
      run();
    }
    if (!n.isLoyaltyLion) {
      window.loyaltylion = n;
      void 0 === window.lion && (window.lion = n);
      n.version = 2;
      n.isLoyaltyLion = !0;
      var i = new Date,
        e =
          i.getFullYear().toString() +
          i.getMonth().toString() +
          i.getDate().toString();
      o('https://sdk.loyaltylion.net/static/2/loader.js?t=' + e);
      var r = !1;
      n.init = function (t) {
        if (r) throw new Error('Cannot call lion.init more than once');
        r = !0;
        var a = (n._token = t.token);
        if (!a) throw new Error('Token must be supplied to lion.init');
        for (
          var l = [],
            s =
              '_push configure bootstrap shutdown on removeListener authenticateCustomer'.split(
                ' '
              ),
            c = 0;
          c < s.length;
          c += 1
        )
          !(function (t, n) {
            t[n] = function () {
              l.push([n, Array.prototype.slice.call(arguments, 0)]);
            };
          })(n, s[c]);
        o(
          'https://sdk.loyaltylion.net/sdk/start/' +
            a +
            '.js?t=' +
            e +
            i.getHours().toString()
        );
        n._initData = t;
        n._buffer = l;
      };
    }
  }(document, window.loyaltylion || [], llDefer);

  {% if shop.metafields.loyaltylion.token != nil %}
    {% if customer != nil and customer.has_account %}
      {% assign date = 'now' | date: "%Y-%m-%d %H:%M:%S%z" %}
      {% assign auth_token =
        customer.id | append: date | append: customer.email | append: shop.metafields.loyaltylion.secret | sha1 %}

      loyaltylion.init({
        token: "{{ shop.metafields.loyaltylion.token }}",
        customer: {
          id: "{{ customer.id }}",
          email: "{{ customer.email }}",
          name: "{{ customer.name }}",
          rechargeHash: "{{ customer.metafields.subscriptions.customer_string | if: customer.metafields.subscriptions.customer_string }}"
        },
        auth: {
          date: "{{ date }}",
          token: "{{ auth_token }}"
        },
      });
    {% else %}
      loyaltylion.init({ token: "{{ shop.metafields.loyaltylion.token }}" });
    {% endif %}

    /*
     * Double-init guard 2026-04-29 — discovered via the GA4 js_error
     * pipeline (now correctly populating after the GTM tag fix this
     * session): every page load throws
     *   "Uncaught Error: Cannot call lion.init more than once"
     * because the LoyaltyLion Shopify App Embed block ALSO calls
     * loyaltylion.init({token}) in its own injected script
     * (rendered ~1370 lines into the page HTML, marked
     *  <!-- loyaltylion.snippet.version=a2737380ee+9620 -->), and the
     * SDK's bootstrap explicitly throws on the second init call.
     *
     * Theme runs first (this snippet, in <head>), so our init wins —
     * we initialize with the full secure customer auth (token + auth.date
     * + auth.token sha1 hash), which is more complete than the App
     * Embed's anonymous { token } call. Then we neutralize subsequent
     * init() calls so the App Embed's later call becomes a silent no-op
     * instead of throwing.
     *
     * This preserves: app embed auto-update path (the loader bytes are
     * still maintained by LoyaltyLion via Shopify), theme-side customer
     * auth (still under our control). Eliminates: the runtime exception
     * that was breaking JS execution after the App Embed loaded.
     *
     * Alternative fix (deferred): disable the LoyaltyLion App Embed in
     * Shopify Admin → Online Store → Themes → Customize → App Embeds.
     * Cleaner long-term, but requires admin action and breaks if anyone
     * re-enables the embed by accident. Theme-side guard is defense-in-depth.
     */
    if (window.loyaltylion) {
      loyaltylion.init = function() { /* no-op — already initialized by theme snippet */ };
    }
  {% endif %}
})();
</script>
