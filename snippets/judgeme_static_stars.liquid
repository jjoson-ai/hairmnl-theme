{%- comment -%}
  Server-rendered Judge.me preview stars. Emits 5 discrete star spans,
  each in one of 3 states: full / half / empty. Visual fidelity matches
  Judge.me's hydrated look (color #CFAF8B = the Judge.me-installed gold).

  Half-star rounding mirrors Judge.me's UI:
    remainder < 0.25  → no half (truncate down)
    0.25–0.74         → render a half star
    remainder >= 0.75 → round up to a full star
  Examples: 4.66 → 4½ (4 full + 1 half), 4.84 → 5 full, 4.20 → 4 full + 1 empty.

  Params:
    rating        numeric 0-5 (e.g. 4.66)
    count         integer review count
    size          'sm' | 'md' (default 'sm')
    show_count    optional boolean (default true)
    scroll_target optional anchor href (e.g. '#judgeme_product_reviews').
                  When present, wraps stars in <a> for click-to-scroll.
                  Pass only on pages that contain the target element.
{%- endcomment -%}
{%- assign _jm_rating = rating | default: 0 | times: 1.0 -%}
{%- assign _jm_count = count | default: 0 | times: 1 -%}
{%- if _jm_count > 0 -%}
  {%- assign _jm_full = _jm_rating | floor -%}
  {%- assign _jm_remainder_x100 = _jm_rating | minus: _jm_full | times: 100 | round -%}
  {%- assign _jm_half = 0 -%}
  {%- if _jm_remainder_x100 >= 25 and _jm_remainder_x100 < 75 -%}
    {%- assign _jm_half = 1 -%}
  {%- elsif _jm_remainder_x100 >= 75 -%}
    {%- assign _jm_full = _jm_full | plus: 1 -%}
  {%- endif -%}
  {%- assign _jm_empty = 5 | minus: _jm_full | minus: _jm_half -%}
  {%- if scroll_target != blank -%}<a href="{{ scroll_target }}" class="jm-stars-static-link">{%- endif -%}
  <span class="jm-stars-static jm-stars-static--{{ size | default: 'sm' }}" role="img" aria-label="Rated {{ _jm_rating }} out of 5 stars based on {{ _jm_count }} reviews">
    {%- if _jm_full > 0 -%}{%- for i in (1.._jm_full) -%}<span class="jm-star jm-star--on" aria-hidden="true">★</span>{%- endfor -%}{%- endif -%}
    {%- if _jm_half == 1 -%}<span class="jm-star jm-star--half" aria-hidden="true">★</span>{%- endif -%}
    {%- if _jm_empty > 0 -%}{%- for i in (1.._jm_empty) -%}<span class="jm-star jm-star--off" aria-hidden="true">★</span>{%- endfor -%}{%- endif -%}
    {%- if show_count != false -%}
      <span class="jm-stars-static__count">{{ _jm_count }} {% if _jm_count == 1 %}review{% else %}reviews{% endif %}</span>
    {%- endif -%}
  </span>
  {%- if scroll_target != blank -%}</a>{%- endif -%}
{%- endif -%}
