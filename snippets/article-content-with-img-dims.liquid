{%- comment -%}
  article-content-with-img-dims.liquid

  Post-processor for `article.content` HTML that injects explicit
  width/height attributes onto <img> tags whose src URL encodes
  Shopify CDN dimensions in the standard `_WIDTHxHEIGHT.ext` pattern
  (e.g. `cdn.shopify.com/.../filename_480x480.jpg?v=...`).

  Why: Shopify's rich-text editor inserts <img> tags WITHOUT any
  width/height attributes. Browsers can't reserve layout space for
  unsized images → all content below shifts when each image loads →
  catastrophic CLS. Field RUM showed 4 of top 5 worst-CLS pages were
  blog posts at 49–55% poor (mobile, n=51–392 events per page).

  Today's earlier CSS fix (snippets/css-overrides.liquid) added
  aspect-ratio: auto 16/9 fallback — helps but landscape vs portrait
  images still snap when they load. THIS snippet eliminates the snap
  for all Shopify-CDN-hosted images by parsing the dimensions out of
  the URL and injecting them as HTML attributes. Browser then knows
  the EXACT aspect ratio at HTML parse time, before the image load.

  Usage (in sections/article.liquid):
    {% render 'article-content-with-img-dims', content: article.content %}

  The "with-img-dims" naming makes it obvious that other
  ${something}.content callers (page.content, product.description)
  should also be candidates if they have the same problem.

  Algorithm:
    1. Split content on '<img ' to get chunks. chunk[0] is everything
       before the first <img tag (passes through unchanged).
    2. For each subsequent chunk: reconstruct as '<img ' + chunk_open
       + '>' + chunk_tail. The tag opens with chunk_open up to the
       first '>'; everything after is tail (the next paragraph etc.).
    3. Within chunk_open, look for src="..." then parse the URL for
       a final-segment underscore-then-WxH-then-dot pattern.
    4. If found AND the tag doesn't already have width/height attrs,
       inject them right after '<img '. Also inject loading="lazy"
       and decoding="async" if missing (perf bonus, doesn't affect CLS).
    5. Reassemble.

  Limitations:
    - Only matches Shopify CDN URLs ending in `_NNNxMMM.ext` or
      `_NNNxMMM.ext?...` patterns. Other URL shapes pass through
      unchanged (CSS aspect-ratio fallback still helps those).
    - Handles ONE pattern of underscore-x-dot. Filenames with
      underscores in the basename work because we split on ALL
      underscores and use the LAST chunk before the dot.
    - Doesn't handle <picture><source> nesting (Shopify rich text
      editor doesn't emit <picture> directly).
    - Liquid has no regex; this uses split/replace chains only.
{%- endcomment -%}

{%- assign _src_content = content | default: '' -%}

{%- comment -%}
  Defensive repair for malformed <a ... target="_blank"<img ...> patterns.
  Applied in TWO passes:
    1. BEFORE the <img split: catches malformation already in article.content
    2. AFTER the <img split + reassembly: catches malformation introduced by
       our own dimension-injection algorithm (Shopify sanitizes article.content
       to close <a> tags, but our split on '<img ' may lose the closing '>' of
       the parent <a> tag in some edge cases).
  The general-pattern repair '"<img' → '"><img' catches any closing attribute
  quote immediately followed by <img (never valid in HTML — means the parent
  tag's closing > was lost).
{%- endcomment -%}
{%- assign _src_content = _src_content | replace: 'target="_blank"<img ', 'target="_blank"><img ' | replace: 'target="_self"<img ', 'target="_self"><img ' -%}
{%- assign _src_content = _src_content | replace: "target='_blank'<img ", "target='_blank'><img " | replace: "target='_self'<img ", "target='_self'><img " -%}
{%- assign _src_content = _src_content | replace: 'target="_blank"<img', 'target="_blank"><img' | replace: 'target="_self"<img', 'target="_self"><img' -%}
{%- assign _src_content = _src_content | replace: "target='_blank'<img", "target='_blank'><img" | replace: "target='_self'<img", "target='_self'><img" -%}
{%- assign _src_content = _src_content | replace: '"<img ', '"><img ' | replace: '"<img', '"><img' -%}

{%- assign _img_chunks = _src_content | split: '<img ' -%}
{%- assign _output = _img_chunks | first -%}

{%- for _chunk in _img_chunks offset: 1 -%}
  {%- comment -%} Split chunk into "img attributes" + "rest of content after the > closing tag" {%- endcomment -%}
  {%- assign _gt_split = _chunk | split: '>' -%}
  {%- assign _img_attrs = _gt_split | first -%}
  {%- assign _tail_size = _gt_split.size | minus: 1 -%}
  {%- comment -%} _tail = everything after the first '>' — possibly contains more '>' characters, so we have to rejoin {%- endcomment -%}
  {%- assign _tail = '' -%}
  {%- for _piece in _gt_split offset: 1 -%}
    {%- if forloop.first -%}
      {%- assign _tail = _piece -%}
    {%- else -%}
      {%- assign _tail = _tail | append: '>' | append: _piece -%}
    {%- endif -%}
  {%- endfor -%}

  {%- comment -%} Skip rewriting if the tag already has width="" or height="" attrs {%- endcomment -%}
  {%- assign _has_dims = false -%}
  {%- if _img_attrs contains 'width=' or _img_attrs contains 'height=' -%}
    {%- assign _has_dims = true -%}
  {%- endif -%}

  {%- comment -%} Extract src URL value (between src=" and the next ") {%- endcomment -%}
  {%- assign _src_url = '' -%}
  {%- if _img_attrs contains 'src="' -%}
    {%- assign _after_src = _img_attrs | split: 'src="' | last -%}
    {%- assign _src_url = _after_src | split: '"' | first -%}
  {%- endif -%}

  {%- comment -%}
    Try to parse `_WIDTHxHEIGHT.ext` from the URL. Approach:
      - Strip query string (everything after the first '?').
      - Take the LAST segment of the path (after the last '/') — typically the filename.
      - Strip the file extension (everything after the last '.').
      - Take the LAST chunk after splitting on '_' (typically the dimension token).
      - If that token contains 'x' surrounded by digits, split on 'x' to get width/height.
  {%- endcomment -%}
  {%- assign _w = '' -%}
  {%- assign _h = '' -%}
  {%- if _src_url != '' and _has_dims == false -%}
    {%- assign _no_query = _src_url | split: '?' | first -%}
    {%- assign _filename = _no_query | split: '/' | last -%}
    {%- assign _no_ext_parts = _filename | split: '.' -%}
    {%- assign _no_ext = '' -%}
    {%- if _no_ext_parts.size > 1 -%}
      {%- comment -%} Drop the LAST element (extension), rejoin the rest with '.' for filenames containing dots {%- endcomment -%}
      {%- assign _ext_keep_count = _no_ext_parts.size | minus: 1 -%}
      {%- for _p in _no_ext_parts limit: _ext_keep_count -%}
        {%- if forloop.first -%}
          {%- assign _no_ext = _p -%}
        {%- else -%}
          {%- assign _no_ext = _no_ext | append: '.' | append: _p -%}
        {%- endif -%}
      {%- endfor -%}
    {%- else -%}
      {%- assign _no_ext = _filename -%}
    {%- endif -%}

    {%- comment -%} Last underscore-delimited token e.g. "480x480" {%- endcomment -%}
    {%- assign _dim_token = _no_ext | split: '_' | last -%}
    {%- if _dim_token contains 'x' -%}
      {%- assign _wh = _dim_token | split: 'x' -%}
      {%- if _wh.size == 2 -%}
        {%- assign _w_candidate = _wh[0] -%}
        {%- assign _h_candidate = _wh[1] -%}
        {%- comment -%}
          Validate both halves are pure digits (avoids false positives on
          file names like "before-x-after"). Liquid has no regex — use
          plus: 0 trick (parses to int, returns 0 on non-numeric strings),
          then compare back-to-string equality.
        {%- endcomment -%}
        {%- assign _w_int = _w_candidate | plus: 0 -%}
        {%- assign _h_int = _h_candidate | plus: 0 -%}
        {%- if _w_int > 0 and _h_int > 0 -%}
          {%- assign _w_back = _w_int | append: '' -%}
          {%- assign _h_back = _h_int | append: '' -%}
          {%- if _w_back == _w_candidate and _h_back == _h_candidate -%}
            {%- assign _w = _w_candidate -%}
            {%- assign _h = _h_candidate -%}
          {%- endif -%}
        {%- endif -%}
      {%- endif -%}
    {%- endif -%}
  {%- endif -%}

  {%- comment -%} Build the rewritten <img ...> tag {%- endcomment -%}
  {%- assign _new_attrs = _img_attrs -%}
  {%- assign _inject = '' -%}

  {%- comment -%}
    xlcm 2026-05-27: loading/fetchpriority/decoding injection moved OUTSIDE
    the dim-detection conditional. Previously these only applied when the
    src URL contained the _WIDTHxHEIGHT.ext pattern — admin-pasted images
    without that pattern (e.g. plain Davines_This_Is_A_Blow_Dry_Primer.jpg)
    were left with no loading attr at all (browser default = eager).
    Article LCP investigation in bd xttq found 6 such images on the test
    article wasting bandwidth in the LCP critical window.
  {%- endcomment -%}
  {%- if _w != '' and _h != '' -%}
    {%- assign _inject = _inject | append: 'width="' | append: _w | append: '" height="' | append: _h | append: '" ' -%}
  {%- endif -%}

  {%- comment -%}
    LCP priority for the FIRST in-body image (issue 7tq, 2026-05-10).
    GA4 RUM attribution showed first body image is the LCP candidate on
    42-45% of poor LCP events. Inject fetchpriority=high + eager on the
    first <img>, lazy on all subsequent <img> tags. Now applies to ALL
    article body images regardless of URL-encoded dim parseability.
  {%- endcomment -%}
  {%- if forloop.first -%}
    {%- unless _img_attrs contains 'fetchpriority=' -%}
      {%- assign _inject = _inject | append: 'fetchpriority="high" ' -%}
    {%- endunless -%}
    {%- unless _img_attrs contains 'loading=' -%}
      {%- assign _inject = _inject | append: 'loading="eager" ' -%}
    {%- endunless -%}
  {%- else -%}
    {%- unless _img_attrs contains 'loading=' -%}
      {%- assign _inject = _inject | append: 'loading="lazy" ' -%}
    {%- endunless -%}
  {%- endif -%}
  {%- unless _img_attrs contains 'decoding=' -%}
    {%- assign _inject = _inject | append: 'decoding="async" ' -%}
  {%- endunless -%}

  {%- if _inject != '' -%}
    {%- assign _new_attrs = _inject | append: _img_attrs -%}
  {%- endif -%}

  {%- assign _output = _output | append: '<img ' | append: _new_attrs | append: '>' | append: _tail -%}
{%- endfor -%}

{%- comment -%}
  Pass 2: post-reassembly repair. The <img split/reassemble algorithm can
  lose the closing '>' of a parent tag (e.g. <a target="_blank">) when the
  closing '>' is in a previous chunk. Apply the general '"<img' → '"><img'
  repair on the final output to catch these.
{%- endcomment -%}
{%- assign _output = _output | replace: '"<img ', '"><img ' | replace: '"<img', '"><img' -%}
{%- comment -%}
  Pass 3: Shopify themes collapse <div> wrappers around images when they
  follow <ul>/<li> elements. Convert image-containing <div
  style="text-align: center;"> to <p style="text-align: center;"> which
  renders reliably. Bloggle / rich-text stores centered image blocks as:
    <div style="text-align: center;"><a ...><img ...></a></div>
    <div style="text-align: center;"><img ...></div>

  CRITICAL: the open AND its matching close must both convert. An earlier
  version only converted the open, leaving orphan </div> tokens scattered
  through article.content. These orphans then closed parent wrappers
  (blog__article__content, article column) prematurely on the live site
  2026-05-18 — "Bold Blacks" section and below rendered at full body
  width outside the constrained column on /best-hair-color-for-morenas...

  Algorithm: split on the centered-div open marker, then for each
  resulting chunk consume the FIRST </div> as the matching close (HTML
  doesn't allow nested <div> inside an inline text-align wrapper in
  rich-text-editor output, so first-close == matching close in practice).
{%- endcomment -%}

{%- comment -%} ----- variant A: <div style="text-align: center;"> (with space) ----- {%- endcomment -%}
{%- assign _ctr_open_a = '<div style="text-align: center;">' -%}
{%- assign _ctr_parts_a = _output | split: _ctr_open_a -%}
{%- if _ctr_parts_a.size > 1 -%}
  {%- assign _output = _ctr_parts_a | first -%}
  {%- for _chunk in _ctr_parts_a offset: 1 -%}
    {%- assign _inner = _chunk | split: '</div>' -%}
    {%- if _inner.size > 1 -%}
      {%- assign _body = _inner | first -%}
      {%- assign _rest = '' -%}
      {%- for _p in _inner offset: 1 -%}
        {%- if forloop.first -%}
          {%- assign _rest = _p -%}
        {%- else -%}
          {%- assign _rest = _rest | append: '</div>' | append: _p -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign _output = _output | append: '<p style="text-align: center;">' | append: _body | append: '</p>' | append: _rest -%}
    {%- else -%}
      {%- comment -%} No matching </div> found — fall back to open-only conversion {%- endcomment -%}
      {%- assign _output = _output | append: '<p style="text-align: center;">' | append: _chunk -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%} ----- variant B: <div style="text-align:center;"> (no space) ----- {%- endcomment -%}
{%- assign _ctr_open_b = '<div style="text-align:center;">' -%}
{%- assign _ctr_parts_b = _output | split: _ctr_open_b -%}
{%- if _ctr_parts_b.size > 1 -%}
  {%- assign _output = _ctr_parts_b | first -%}
  {%- for _chunk in _ctr_parts_b offset: 1 -%}
    {%- assign _inner = _chunk | split: '</div>' -%}
    {%- if _inner.size > 1 -%}
      {%- assign _body = _inner | first -%}
      {%- assign _rest = '' -%}
      {%- for _p in _inner offset: 1 -%}
        {%- if forloop.first -%}
          {%- assign _rest = _p -%}
        {%- else -%}
          {%- assign _rest = _rest | append: '</div>' | append: _p -%}
        {%- endif -%}
      {%- endfor -%}
      {%- assign _output = _output | append: '<p style="text-align:center;">' | append: _body | append: '</p>' | append: _rest -%}
    {%- else -%}
      {%- assign _output = _output | append: '<p style="text-align:center;">' | append: _chunk -%}
    {%- endif -%}
  {%- endfor -%}
{%- endif -%}

{%- comment -%}
  Pass 3.5: handle WYSIWYG mismatched `<p style=...>... </div>` patterns.
  The 2026-05-18 morena article has the pattern repeated 4 times:
    <p style="text-align: center;"><img ... style="float: none;"></div>

  The author/editor wrote `<p style="...">` as the open but typed `</div>`
  as the close (likely from inline edit of a previously-`<div>`-wrapped
  block). The mismatched close prematurely closes the parent
  blog__article__content wrapper, dumping subsequent content out of the
  article column.

  Fix: targeted literal replacement of common stray patterns. We target
  the specific suffixes observed in production article bodies:
    - `style="float: none;"></div>`
    - `style="margin-bottom: 16px; float: none;"></div>`
    - generic `; float: none;"></div>`
  Plus a fallback: ANY `"></div>` immediately followed by `<p` or `<h`
  (whitespace-tolerant) at the start of the next block element, since
  in article.content that nearly always means a misclosed inline block.

  Safety: these replacements run ONLY on article.content (this snippet
  is scoped to that parameter). Theme chrome (Judge.me medals, Pro
  Blogger product cards, etc.) is not seen by this snippet.
{%- endcomment -%}

{%- assign _output = _output | replace: '; float: none;"></div>', '; float: none;"></p>' -%}
{%- assign _output = _output | replace: 'float: none;"></div>', 'float: none;"></p>' -%}
{%- assign _output = _output | replace: 'float:none;"></div>', 'float:none;"></p>' -%}
{%- assign _output = _output | replace: 'float: left;"></div>', 'float: left;"></p>' -%}
{%- assign _output = _output | replace: 'float: right;"></div>', 'float: right;"></p>' -%}

{%- comment -%}
  Fallback: `"></div>\n<p` or `"></div>\n<h` — a `"></div>` immediately
  followed by a block-element open. In article.content this signals a
  misclosed inline image block. The `replace` handles common whitespace
  variants between the close and the next open.
{%- endcomment -%}
{%- assign _output = _output | replace: '"></div>\n<p', '"></p>\n<p' -%}
{%- assign _output = _output | replace: '"></div>\n<h', '"></p>\n<h' -%}
{%- assign _output = _output | replace: '"></div> <p', '"></p> <p' -%}
{%- assign _output = _output | replace: '"></div> <h', '"></p> <h' -%}
{%- assign _output = _output | replace: '"></div><p', '"></p><p' -%}
{%- assign _output = _output | replace: '"></div><h', '"></p><h' -%}

{%- comment -%}
  Pass 4: balance stray closing tags from WYSIWYG-corrupted article body
  HTML. Defense-in-depth after Pass 3 / 3.5. Root cause: pasting from
  Word / Google Docs / mid-article copy drops extra </div> / </article>
  tokens into article.content. If Pass 3/3.5 missed any (unusual variant
  spacing, nested edge cases), Pass 4 counts opens vs closes per tag and
  strips excess closes from the END of content. No-op when balanced.
{%- endcomment -%}

{%- comment -%} ----- balance </div> ----- {%- endcomment -%}
{%- assign _div_open_parts = _output | split: '<div' -%}
{%- assign _div_open_count = _div_open_parts.size | minus: 1 -%}
{%- assign _div_close_parts = _output | split: '</div>' -%}
{%- assign _div_close_count = _div_close_parts.size | minus: 1 -%}
{%- if _div_close_count > _div_open_count -%}
  {%- assign _div_keep = _div_open_count -%}
  {%- assign _rebuilt = '' -%}
  {%- for _piece in _div_close_parts -%}
    {%- if forloop.first -%}
      {%- assign _rebuilt = _piece -%}
    {%- elsif forloop.index0 <= _div_keep -%}
      {%- assign _rebuilt = _rebuilt | append: '</div>' | append: _piece -%}
    {%- else -%}
      {%- assign _rebuilt = _rebuilt | append: _piece -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign _output = _rebuilt -%}
{%- endif -%}

{%- comment -%} ----- balance </article> ----- {%- endcomment -%}
{%- assign _art_open_parts = _output | split: '<article' -%}
{%- assign _art_open_count = _art_open_parts.size | minus: 1 -%}
{%- assign _art_close_parts = _output | split: '</article>' -%}
{%- assign _art_close_count = _art_close_parts.size | minus: 1 -%}
{%- if _art_close_count > _art_open_count -%}
  {%- assign _art_keep = _art_open_count -%}
  {%- assign _rebuilt = '' -%}
  {%- for _piece in _art_close_parts -%}
    {%- if forloop.first -%}
      {%- assign _rebuilt = _piece -%}
    {%- elsif forloop.index0 <= _art_keep -%}
      {%- assign _rebuilt = _rebuilt | append: '</article>' | append: _piece -%}
    {%- else -%}
      {%- assign _rebuilt = _rebuilt | append: _piece -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign _output = _rebuilt -%}
{%- endif -%}

{%- comment -%} ----- balance </section> ----- {%- endcomment -%}
{%- assign _sec_open_parts = _output | split: '<section' -%}
{%- assign _sec_open_count = _sec_open_parts.size | minus: 1 -%}
{%- assign _sec_close_parts = _output | split: '</section>' -%}
{%- assign _sec_close_count = _sec_close_parts.size | minus: 1 -%}
{%- if _sec_close_count > _sec_open_count -%}
  {%- assign _sec_keep = _sec_open_count -%}
  {%- assign _rebuilt = '' -%}
  {%- for _piece in _sec_close_parts -%}
    {%- if forloop.first -%}
      {%- assign _rebuilt = _piece -%}
    {%- elsif forloop.index0 <= _sec_keep -%}
      {%- assign _rebuilt = _rebuilt | append: '</section>' | append: _piece -%}
    {%- else -%}
      {%- assign _rebuilt = _rebuilt | append: _piece -%}
    {%- endif -%}
  {%- endfor -%}
  {%- assign _output = _rebuilt -%}
{%- endif -%}

{{- _output -}}
