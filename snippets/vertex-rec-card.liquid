{%- comment -%}
  Vertex AI Recommendations — shared card partial.
  Used by every rec slot (PDP FBT, cart, home RFY, PDP similar, drawer).

  Two layouts:
  - Default vertical card: clickable <a> wrapping image + content. Used
    on PDP, home, drawer placements. Card click → PDP.
  - Cart compact card (placement == 'cart_above_checkout'): horizontal
    image-left + content-right with an inline ADD button. Built around
    a {% form 'product' %} so submit → /cart/add via native HTML form
    (page reloads, Shopify default). No AJAX, no new JS.

  Arguments:
    product   {Product}  required — the product to render
    placement {String}   optional — passed through for slot-specific variants
{%- endcomment -%}

{%- liquid
  assign on_sale = false
  if product.compare_at_price > product.price
    assign on_sale = true
  endif
  assign sold_out = true
  if product.available
    assign sold_out = false
  endif
  assign img = product.featured_media.preview_image
  assign first_variant = product.first_available_variant
-%}

{%- comment -%} Reusable image markup. {%- endcomment -%}
{%- capture card_image -%}
  <div class="vrec-card__image">
    {%- if img -%}
      <picture>
        <source type="image/webp"
                srcset="{% if img.width > 360 %}{{ img | image_url: width: 360, format: 'webp' }} 360w,{% endif %}
                        {% if img.width > 540 %}{{ img | image_url: width: 540, format: 'webp' }} 540w,{% endif %}
                        {% if img.width > 720 %}{{ img | image_url: width: 720, format: 'webp' }} 720w{% endif %}"
                sizes="(min-width: 1024px) 22vw, (min-width: 640px) 30vw, 42vw">
        <img
          src="{{ img | image_url: width: 540 }}"
          srcset="{% if img.width > 360 %}{{ img | image_url: width: 360 }} 360w,{% endif %}
                  {% if img.width > 540 %}{{ img | image_url: width: 540 }} 540w,{% endif %}
                  {% if img.width > 720 %}{{ img | image_url: width: 720 }} 720w{% endif %}"
          sizes="(min-width: 1024px) 22vw, (min-width: 640px) 30vw, 42vw"
          width="{{ img.width }}"
          height="{{ img.height }}"
          loading="lazy"
          alt="{{ img.alt | default: product.title | strip_html | escape }}">
      </picture>
    {%- else -%}
      <div class="vrec-card__image-placeholder" aria-hidden="true"></div>
    {%- endif -%}
    {%- if sold_out -%}
      <span class="vrec-card__badge vrec-card__badge--sold">{{ 'products.product.sold_out' | t }}</span>
    {%- elsif on_sale -%}
      <span class="vrec-card__badge vrec-card__badge--sale">{{ 'products.product.sale' | t }}</span>
    {%- endif -%}
  </div>
{%- endcapture -%}

{%- if placement == 'cart_above_checkout' -%}
  {%- comment -%}
    Cart compact card — horizontal layout with inline ADD-to-cart button.
    Wrapped in {% form 'product' %} so the button does a native submit to
    /cart/add. After submit, Shopify redirects back to /cart with the new
    line item appended. Page reload — but matches the existing site
    pattern where {% form 'product', show_form: true %} is used on the
    product page upsell.
  {%- endcomment -%}
  <div class="vrec-card vrec-card--compact{% if sold_out %} vrec-card--sold-out{% endif %}"
       data-vertex-product-id="{{ product.id }}">
    <a class="vrec-card__image-link" href="{{ product.url }}" aria-label="{{ product.title | strip_html | escape }}">
      {{ card_image }}
    </a>
    <div class="vrec-card__info">
      {%- if product.vendor != blank -%}
        <p class="vrec-card__vendor">
          <a href="{{ product.url }}" class="vrec-card__vendor-link">{{ product.vendor }}</a>
        </p>
      {%- endif -%}
      <p class="vrec-card__title">
        <a href="{{ product.url }}" class="vrec-card__title-link">{{ product.title | strip_html }}</a>
      </p>
      <div class="vrec-card__bottom">
        <p class="vrec-card__price{% if on_sale %} vrec-card__price--sale{% endif %}">
          <span class="vrec-card__price-current">{{ product.price | money }}</span>
          {%- if on_sale -%}
            <span class="vrec-card__price-compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </p>
        {%- if first_variant and first_variant.available -%}
          {%- form 'product', product, class: 'vrec-card__cta-form' -%}
            <input type="hidden" name="id" value="{{ first_variant.id }}">
            <input type="hidden" name="quantity" value="1">
            <button type="submit"
                    name="add"
                    class="vrec-card__cta uppercase">
              {{ 'products.general.upsell_add_to_cart' | t | default: 'Add to cart' }}
            </button>
          {%- endform -%}
        {%- else -%}
          <span class="vrec-card__sold-out-label">{{ 'products.product.sold_out' | t }}</span>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- else -%}
  {%- comment -%} Default vertical card — whole card is the click target. {%- endcomment -%}
  <a class="vrec-card{% if sold_out %} vrec-card--sold-out{% endif %}"
     href="{{ product.url }}"
     role="listitem"
     data-vertex-product-id="{{ product.id }}">
    {{ card_image }}
    <div class="vrec-card__info">
      {%- if product.vendor != blank -%}
        <p class="vrec-card__vendor">{{ product.vendor }}</p>
      {%- endif -%}
      <p class="vrec-card__title">{{ product.title | strip_html }}</p>
      {%- if product.metafields.reviews.rating.value != blank -%}
        <div class="vrec-card__rating">
          {%- render 'product-rating', product: product, show_rating_count: true -%}
        </div>
      {%- endif -%}
      <p class="vrec-card__price{% if on_sale %} vrec-card__price--sale{% endif %}">
        <span class="vrec-card__price-current">{{ product.price | money }}</span>
        {%- if on_sale -%}
          <span class="vrec-card__price-compare">{{ product.compare_at_price | money }}</span>
        {%- endif -%}
      </p>
    </div>
  </a>
{%- endif -%}
