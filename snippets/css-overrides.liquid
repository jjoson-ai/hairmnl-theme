<style>
  .header__desktop {
    height: 70px;
  }

  .header__mobile {
    height: 60px;
  }

  /* CLS fix 2026-04-28 — Judge.me 'Verified by' logo image is rendered
     by app HTML without explicit width/height attributes. PSI flagged
     it as "Media element lacking an explicit size" causing layout
     shifts where the .jdgm-medals-wrapper appears (PDP footer +
     /reviews page). Reserving the rendered dimensions (125x24 per
     Lighthouse boundingRect) prevents the shift. Aspect ratio also
     declared so width: 100% containers compute height correctly. */
  .jdgm-verified-by__image {
    display: inline-block;
    width: 125px;
    height: 24px;
  }
  .jdgm-verified-by__image img {
    width: 100%;
    height: 100%;
    display: block;
    aspect-ratio: 125 / 24;
  }
</style>