/* Announcement bar */
---color-announcement-bg: var(--COLOR-ANNOUNCEMENT-BG);
---color-announcement-text: var(--COLOR-ANNOUNCEMENT-TEXT);

/* Badges */
---color-badge: var(--COLOR-BADGE);
---color-badge-text: var(--COLOR-BADGE-TEXT);

/* Buttons (no dedicated --BTN-* source; alias to primary palette) */
---btn-bg-color: var(--COLOR-PRIMARY);
---btn-text-color: var(--COLOR-PRIMARY-OPPOSITE);
---btn-border-color: var(--COLOR-PRIMARY);
---btn-hover-bg-color: var(--COLOR-PRIMARY-HOVER);
---btn-hover-text-color: var(--COLOR-PRIMARY-OPPOSITE);
---btn-hover-border-color: var(--COLOR-PRIMARY-HOVER);
---button-radius: var(--BUTTON-RADIUS);

/* Select dropdown icon — small SVG arrow */
---ico-select: url("data:image/svg+xml;charset=utf-8,%3Csvg xmlns='http://www.w3.org/2000/svg' width='10' height='6' viewBox='0 0 10 6'%3E%3Cpath d='M1 1l4 4 4-4' stroke='currentColor' fill='none'/%3E%3C/svg%3E");

}

