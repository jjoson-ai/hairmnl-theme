{%- comment -%}
  article-itemlist-schema.liquid — ItemList JSON-LD for product-roundup blog articles.
  Marks the products a "best of" listicle already lists VISIBLY (content-matching, not fabricated),
  giving Google + AI a clean "curated list" signal. bd hairmnl-theme-0kv3.3 (GEO Capitalize epic).
  Gated by article.handle. Keep the product list in sync with the article body if it changes.
  {# MIGRATION-DEBT: bespoke P6 GEO schema; port to OS-2.0 metaobject-driven section. reason = Smart SEO
     emits Article/FAQ but not ItemList for roundups. See os2-migration/customization-audit.md #}
{%- endcomment -%}
{%- if template contains 'article' and article.handle == '15-top-sulfate-free-shampoos-in-the-philippines' -%}
{%- assign u = shop.url -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Best Sulfate-Free Shampoos in the Philippines",
  "url": "{{ u }}{{ article.url }}",
  "numberOfItems": 11,
  "itemListOrder": "https://schema.org/ItemListUnordered",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "item": { "@type": "Product", "name": "Davines Purifying Shampoo", "url": "{{ u }}/products/davines-naturaltech-purifying-shampoo-for-scalp-with-oily-or-dry-dandruff" } },
    { "@type": "ListItem", "position": 2, "item": { "@type": "Product", "name": "Davines Energizing Shampoo", "url": "{{ u }}/products/davines-naturaltech-energizing-shampoo-for-scalp-with-fragile-thinning-hair" } },
    { "@type": "ListItem", "position": 3, "item": { "@type": "Product", "name": "Davines OI Absolute Beautifying Shampoo", "url": "{{ u }}/products/davines-oi-shampoo-absolute-beautifying-shampoo-with-roucou-oil" } },
    { "@type": "ListItem", "position": 4, "item": { "@type": "Product", "name": "Davines Well-Being Shampoo", "url": "{{ u }}/products/davines-naturaltech-well-being-shampoo-for-all-kinds-of-hair" } },
    { "@type": "ListItem", "position": 5, "item": { "@type": "Product", "name": "Davines NOUNOU Nourishing Shampoo", "url": "{{ u }}/products/davines-essentials-nounou-shampoo-nourishing-shampoo-for-highly-processed-or-brittle-hair" } },
    { "@type": "ListItem", "position": 6, "item": { "@type": "Product", "name": "Davines LOVE Smoothing Shampoo", "url": "{{ u }}/products/davines-essentials-love-shampoo-lovely-smoothing-shampoo-for-coarse-or-frizzy-hair" } },
    { "@type": "ListItem", "position": 7, "item": { "@type": "Product", "name": "Davines Renewing Shampoo", "url": "{{ u }}/products/davines-renewing-shampoo" } },
    { "@type": "ListItem", "position": 8, "item": { "@type": "Product", "name": "Davines LOVE Curl Enhancing Shampoo", "url": "{{ u }}/products/davines-essentials-love-curl-enhancing-shampoo-lovely-curl-enhancing-shampoo-for-wavy-or-curly-hair" } },
    { "@type": "ListItem", "position": 9, "item": { "@type": "Product", "name": "Davines VOLU Volume Enhancing Shampoo", "url": "{{ u }}/products/davines-essentials-volu-shampoo-volume-enhancing-shampoo-for-fine-or-limp-hair" } },
    { "@type": "ListItem", "position": 10, "item": { "@type": "Product", "name": "Kerastase Chroma Absolu Sulfate-Free Shampoo", "url": "{{ u }}/products/kerastase-chroma-absolu-sulfate-free-shampoo-thin-hair" } },
    { "@type": "ListItem", "position": 11, "item": { "@type": "Product", "name": "Davines Calming Shampoo", "url": "{{ u }}/products/davines-naturaltech-calming-shampoo-for-sensitive-scalp" } }
  ]
}
</script>
{%- endif -%}
