  "alternateName": "HairMNL Studio - Serendra BGC",
  "description": "HairMNL Studio's BGC branch in Taguig, offering expert cuts, color, highlights, smoothing treatments, digital perms, professional makeup, and event hairstyling using premium aftercare brands sold on hairmnl.com.",
  "url": "{{ shop.url }}/pages/studio-serendra",
  "telephone": "+63-917-117-9935",
  "image": [
    "{{ shop.url }}/cdn/shop/files/Client_Reviews_-_Serendra_1.png",
    "{{ shop.url }}/cdn/shop/files/Professional_Friendly_Stylists_-_Serendra.png",
    "{{ shop.url }}/cdn/shop/files/High_Quality_Salon_Products_-_Serendra.png"
  ],
  "priceRange": "₱₱",
  "currenciesAccepted": "PHP",
  "paymentAccepted": "Cash, Credit Card, Debit Card, GCash",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "2F Serendra, McKinley Parkway, Post Proper Northside",
    "addressLocality": "Taguig",
    "addressRegion": "Metro Manila",
    "postalCode": "1634",
    "addressCountry": "PH"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 14.5498413,
    "longitude": 121.0543159
  },
  "hasMap": "https://maps.app.goo.gl/JendSjjfJDWcriKK7",
  "openingHoursSpecification": [{
    "@type": "OpeningHoursSpecification",
    "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday","Sunday"],
    "opens": "10:00",
    "closes": "20:00"
  }],
  "sameAs": [
    "https://www.facebook.com/HairMNLStudio/",
    "https://www.instagram.com/hairmnlstudio/"
  ],
  "parentOrganization": {
    "@type": "Organization",
    "name": "HairMNL",
    "url": "{{ shop.url }}"
  }
}
</script>
{%- endif -%}
