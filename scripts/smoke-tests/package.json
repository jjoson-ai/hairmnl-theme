{
  "name": "hairmnl-smoke-tests",
  "version": "1.0.0",
  "private": true,
  "description": "Playwright smoke tests for the P8 cutover — behavioral verification of the 7 smoke checks documented in os2-migration/p8-cutover-operator-playbook.html",
  "scripts": {
    "test": "playwright test",
    "test:smoke-1": "playwright test smoke-01",
    "test:smoke-2": "playwright test smoke-02",
    "test:smoke-3": "playwright test smoke-03",
    "test:smoke-4": "playwright test smoke-04",
    "test:smoke-5": "playwright test smoke-05",
    "test:smoke-6": "playwright test smoke-06",
    "test:smoke-7": "playwright test smoke-07",
    "test:smoke-8": "playwright test smoke-08",
    "test:visual": "playwright test smoke-08",
    "update-baselines": "playwright test smoke-08 --update-snapshots",
    "test:parity": "SHOPIFY_AUTH=.auth/storageState.json playwright test smoke-09 --reporter=list",
    "parity:report": "node bin/parity-report.mjs",
    "parity:open": "npm run parity:report && open parity-screenshots/index.html",
    "test:smoke-9": "playwright test smoke-09",
    "test:smoke-10": "playwright test smoke-10",
    "test:fouc": "playwright test smoke-10 --reporter=list",
    "smoke:dev": "bash bin/smoke-against-dev-server.sh",
    "smoke:dev:baselines": "bash bin/smoke-against-dev-server.sh --update-snapshots smoke-08",
    "test:mobile": "playwright test --project=mobile",
    "test:desktop": "playwright test --project=desktop",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "install-browsers": "playwright install chromium webkit",
    "auth": "node bin/capture-auth.mjs",
    "auth:attach": "node bin/attach-and-save.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/pngjs": "^6.0.5",
    "pixelmatch": "^7.2.0",
    "pngjs": "^7.0.0"
  }
}
