          "bbe65342-6f2d-4454-a547-f6c6434f9dfc": {
            "type": "right_media_with_text",
            "settings": {
              "right_media_with_text_section_title": "Want 99% Less Breakage & 78% Less Split Ends*",
              "right_media_with_text_media_html": "<iframe width=\"560\" height=\"315\" src=\"https://www.youtube.com/embed/M3mUxvic5o4?rel=0\" frameborder=\"0\" allow=\"autoplay; encrypted-media\" allowfullscreen=\"\"></iframe>",
              "right_media_with_text_copy": "Tired of asking your stylist for a trim in order to keep your hair healthy? Extentioniste targets hair fiber from root to tip to keep it fortified while repairing split ends and breakage.<br><br>\n\n<i>* Following in-salon and at home training program (In-salon Soin 1 and Soin 2 not available in the Philippines)</i>"
            }
          },
          "13f54a73-c16d-453b-a77d-90cbf9b4dee6": {
            "type": "left_image_with_text",
            "settings": {
              "left_image_with_text_section_title": "Go to Great Lengths",
              "left_image_with_text_image": "shopify://shop_images/HeroBanner_1_1800x_b1b44265-1ec7-4599-9561-fa9ce3a661ed.webp",
              "left_image_with_text_copy": "Introducing Résistance Extentioniste, the ultimate advantage in the quest for long hair. It’s a new family of products focused on keeping hair strong and healthy, so it can grow as long as you like, always looking glossy and gorgeous.<br><br>\n<a href=\"https://www.hairmnl.com/blogs/product-spotlight/go-to-great-lengths\">Learn More</a>"
            }
          },
          "a4a77417-f398-476e-a013-6b28547d41a6": {
            "type": "right_image_with_text",
            "settings": {
              "right_image_with_text_section_title": "Extend Your Limits. Spring Training for Long Hair",
              "right_image_with_text_image": "shopify://shop_images/Kera_-_1_1800x_50b9d03b-2cdb-4d5f-8b0a-aa459a3ee165.jpg",
              "right_image_with_text_copy": "With any training program, the goals are strength, stamina and speed. Hair goals aren’t much different. Start your program to get your hair in the best shape of your life.<br><br><a href=\"https://www.hairmnl.com/blogs/product-spotlight/strengthening-training-for-long-hair-kerastase-extentioniste\">Learn More</a>"
            }
          },
          "e24ec360-7998-469a-a74d-230de59a6cb5": {
            "type": "left_image_with_text",
            "settings": {
              "left_image_with_text_section_title": "How to Care For Longer Hair",
              "left_image_with_text_image": "shopify://shop_images/Kerastase_Resistance_Extentioniste_6b1ee500-a55c-4601-b3f4-3e5d6682eff0.jpg",
              "left_image_with_text_copy": "Cascading from a brilliant woman’s head to whatever length she pleases, her hair seems an extension of herself, the next level of her being. The longer it is, the longer it’s been with her, full of secrets, waving in the air with wisdom. “There is something iconic about long hair. Mythical even.”<br><br>\n<a href=\"https://www.hairmnl.com/blogs/product-spotlight/how-to-care-for-longer-hair\">Learn More</a>"
            }
          }
        },
